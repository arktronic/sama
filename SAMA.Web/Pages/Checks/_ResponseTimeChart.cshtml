@model Guid

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Response Time History</h5>
        <div class="btn-group btn-group-sm" role="group" id="chartTimeRangeButtons">
			<button type="button" class="btn btn-outline-secondary" data-chart-hours="3" onclick="updateResponseTimeChart('@Model', 3, this)">3h</button>
			<button type="button" class="btn btn-outline-secondary" data-chart-hours="6" onclick="updateResponseTimeChart('@Model', 6, this)">6h</button>
			<button type="button" class="btn btn-outline-secondary active" data-chart-hours="24" onclick="updateResponseTimeChart('@Model', 24, this)">24h</button>
            <button type="button" class="btn btn-outline-secondary" data-chart-hours="168" onclick="updateResponseTimeChart('@Model', 168, this)">7d</button>
        </div>
    </div>
    <div class="card-body">
        <div style="position: relative; min-height: 400px;">
            <canvas id="responseTimeChart" style="max-height: 400px;"></canvas>
            <div id="chartLoading" class="text-center py-5 d-none" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
            <div id="chartNoData" class="text-center py-5 text-muted d-none" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);">
                No check results available for the selected time period.
            </div>
        </div>
    </div>
</div>

<script>
    (function() {
        let responseTimeChart = null;

        function getStatusColor(status) {
            switch (status) {
                case 'Up':
                    return 'rgb(25, 135, 84)';
                case 'Warn':
                    return 'rgb(255, 193, 7)';
                case 'Down':
                    return 'rgb(220, 53, 69)';
                default:
                    return 'rgb(108, 117, 125)';
            }
        }

        window.updateResponseTimeChart = function(checkId, hours, button) {
            const loadingDiv = document.getElementById('chartLoading');
            const noDataDiv = document.getElementById('chartNoData');
            const canvas = document.getElementById('responseTimeChart');

            document.querySelectorAll('#chartTimeRangeButtons [data-chart-hours]').forEach(btn => btn.classList.remove('active'));
            button.classList.add('active');

            loadingDiv.classList.remove('d-none');
            noDataDiv.classList.add('d-none');
            canvas.style.visibility = 'hidden';

            fetch(`/Checks/Details?handler=History&id=${checkId}&hours=${hours}`)
                .then(response => response.json())
                .then(data => {
                    loadingDiv.classList.add('d-none');

                    if (!data || data.length === 0) {
                        noDataDiv.classList.remove('d-none');
                        canvas.style.visibility = 'hidden';
                        return;
                    }

                    noDataDiv.classList.add('d-none');
                    canvas.style.visibility = 'visible';

                    const now = new Date();
                    const startTime = new Date(now.getTime() - (hours * 60 * 60 * 1000));

                    const labels = data.map(d => new Date(d.timestamp));
                    const responseTimesData = data.map(d => d.responseTimeMs);
                    const statusColors = data.map(d => getStatusColor(d.status));

                    const ctx = canvas.getContext('2d');

                    if (responseTimeChart) {
                        responseTimeChart.destroy();
                    }

                    responseTimeChart = new Chart(ctx, {
                        type: 'line',
                        data: {
                            labels: labels,
                            datasets: [{
                                label: 'Response Time (ms)',
                                data: responseTimesData,
                                borderColor: 'rgb(13, 110, 253)',
                                backgroundColor: 'rgba(13, 110, 253, 0.1)',
                                pointBackgroundColor: statusColors,
                                pointBorderColor: statusColors,
                                pointRadius: 4,
                                pointHoverRadius: 6,
                                tension: 0.1,
                                spanGaps: true
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: true,
                            animation: false,
                            interaction: {
                                mode: 'nearest',
                                intersect: false
                            },
                            plugins: {
                                legend: {
                                    display: true,
                                    position: 'top'
                                },
                                tooltip: {
                                    callbacks: {
                                        title: function(context) {
                                            const date = new Date(context[0].parsed.x);
                                            return date.toLocaleString();
                                        },
                                        label: function(context) {
                                            const dataPoint = data[context.dataIndex];
                                            const lines = [];
                                            
                                            lines.push(`Status: ${dataPoint.status}`);
                                            
                                            if (dataPoint.responseTimeMs !== null) {
                                                lines.push(`Response Time: ${dataPoint.responseTimeMs} ms`);
                                            }
                                            
                                            if (dataPoint.errorMessage) {
                                                lines.push(`Error: ${dataPoint.errorMessage}`);
                                            }
                                            
                                            return lines;
                                        }
                                    }
                                }
                            },
                            scales: {
                                x: {
                                    type: 'time',
                                    min: startTime,
                                    max: now,
                                    time: {
                                        unit: hours <= 24 ? 'hour' : (hours <= 168 ? 'day' : 'day'),
                                        displayFormats: {
                                            hour: 'MMM d, HH:mm',
                                            day: 'MMM d'
                                        }
                                    },
                                    title: {
                                        display: true,
                                        text: 'Time'
                                    }
                                },
                                y: {
                                    beginAtZero: true,
                                    title: {
                                        display: true,
                                        text: 'Response Time (ms)'
                                    }
                                }
                            }
                        }
                    });
                })
                .catch(error => {
                    console.error('Error loading chart data:', error);
                    loadingDiv.classList.add('d-none');
                    noDataDiv.classList.remove('d-none');
                    canvas.style.visibility = 'hidden';
                });
        };

        document.addEventListener('DOMContentLoaded', function() {
            const defaultButton = document.querySelector('#chartTimeRangeButtons [data-chart-hours="24"]');
            if (defaultButton) {
                window.updateResponseTimeChart('@Model', 24, defaultButton);
            }
        });
    })();
</script>
