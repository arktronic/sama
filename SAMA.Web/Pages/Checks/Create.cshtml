@page
@using SAMA.Shared.Constants
@model SAMA.Web.Pages.Checks.CreateModel
@inject SAMA.Web.Services.GlobalSettingsService GlobalSettings
@{
    ViewData["Title"] = "Create Check";
    Layout = "_WorkspaceLayout";
}

<h2 class="mb-3 page-header">Create Check</h2>

<div class="row">
    <div class="col-lg-8">
        <div id="create-check-form-container">
            <form id="create-check-form"
                  method="post"
                  hx-post="/Checks/Create?workspaceId=@Model.WorkspaceId"
                  hx-target="#create-check-form-container"
                  hx-swap="outerHTML"
                  hx-select="#create-check-form-container"
                  hx-indicator="#create-spinner">
                
                <input type="hidden" asp-for="Input.WorkspaceId" />
                
                <partial name="_ValidationSummary" model="ViewData.ModelState" />

                <div class="mb-3">
                    <label asp-for="Input.Name" class="form-label">Check Name</label>
                    @if (ViewData.ModelState.IsValid)
                    {
                        <input asp-for="Input.Name" class="form-control" required autofocus />
                    }
                    else
                    {
                        <input asp-for="Input.Name" class="form-control" required />
                    }
                    <div class="form-text">A descriptive name for this check.</div>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Description" class="form-label">Description</label>
                    <textarea asp-for="Input.Description" class="form-control" rows="2"></textarea>
                    <div class="form-text">Optional description of what this check monitors.</div>
                </div>

                <div class="mb-3" hx-disinherit="*">
                    <label asp-for="Input.CheckType" class="form-label">Check Type</label>
                    <select id="check-type-select"
                            name="Input.CheckType"
                            asp-for="Input.CheckType"
                            asp-items="Model.CheckTypes"
                            class="form-select"
                            required
                            hx-get="/Checks/Create?handler=ConfigFields&workspaceId=@Model.WorkspaceId"
                            hx-target="#config-fields-container"
                            hx-select="#config-fields-container"
                            hx-trigger="change"
                            hx-vals='js:{checkType: document.getElementById("check-type-select").value}'>
                        <option value="">-- Select Check Type --</option>
                    </select>
                    <div class="form-text">The type of monitoring check to perform.</div>
                </div>

                <div id="config-fields-container">
                    @if (Model.Input.CheckType == CheckTypes.Http)
                    {
                        <partial name="_HttpConfigFields" model="Model.Input" />
                    }
                    else if (Model.Input.CheckType == CheckTypes.Tcp)
                    {
                        <partial name="_TcpConfigFields" model="Model.Input" />
                    }
                    else if (Model.Input.CheckType == CheckTypes.Ping)
                    {
                        <partial name="_PingConfigFields" model="Model.Input" />
                    }
                    else if (Model.Input.CheckType == CheckTypes.Dns)
                    {
                        <partial name="_DnsConfigFields" model="Model.Input" />
                    }
                    else if (Model.Input.CheckType == CheckTypes.Tls)
                    {
                        <partial name="_TlsConfigFields" model="Model.Input" />
                    }
                    else if (Model.Input.CheckType == CheckTypes.Script)
                    {
                        <partial name="_ScriptCheckConfigFields" model="Model.Input" />
                    }
                </div>

                <div class="mb-3" hx-disinherit="*">
                    <div>
                        <label asp-for="Input.Schedule" class="form-label">Schedule</label>
                        <div class="btn-group btn-group-sm mb-1 ms-2" role="group" aria-label="Quick interval selections">
                            <button type="button" class="btn btn-outline-secondary" onclick="setSchedule('30')">30s</button>
                            <button type="button" class="btn btn-outline-secondary" onclick="setSchedule('60')">1m</button>
                            <button type="button" class="btn btn-outline-secondary" onclick="setSchedule('300')">5m</button>
                            <button type="button" class="btn btn-outline-secondary" onclick="setSchedule('600')">10m</button>
                            <button type="button" class="btn btn-outline-secondary" onclick="setSchedule('1800')">30m</button>
                            <button type="button" class="btn btn-outline-secondary" onclick="setSchedule('3600')">1h</button>
                            <button type="button" class="btn btn-outline-secondary" onclick="setSchedule('21600')">6h</button>
                            <button type="button" class="btn btn-outline-secondary" onclick="setSchedule('86400')">24h</button>
                        </div>
                    </div>
                    <input asp-for="Input.Schedule" 
                           id="schedule-input"
                           class="form-control"
                           autocomplete="off"
                           required
                           hx-get="/Checks/Create?handler=SchedulePreview&workspaceId=@Model.WorkspaceId"
                           hx-trigger="load, input delay:300ms"
                           hx-target="#schedule-preview" />
                    <div id="schedule-preview" class="form-text fw-semibold ms-3">--</div>
                    <div class="form-text">Interval in seconds (e.g., <code>60</code>) or a <a href="https://www.quartz-scheduler.net/documentation/quartz-3.x/tutorial/crontriggers.html#cron-expressions" target="_blank"  rel="noopener noreferrer">cron expression</a> with seconds (e.g., <code>0 */5 * * * ?</code>). Cron expressions are evaluated in the <strong>@GlobalSettings.TimeZone</strong> time zone.</div>
                </div>
                <script>
                    function setSchedule(value) {
                        const input = document.getElementById('schedule-input');
                        input.value = value;
                        htmx.trigger(input, 'input');
                    }
                </script>

                <div class="mb-3">
                    <label asp-for="Input.TimeoutSeconds" class="form-label">Timeout (seconds)</label>
                    <input asp-for="Input.TimeoutSeconds" class="form-control" type="number" min="5" max="3600" required />
                    <div class="form-text">Maximum time to wait for a response before marking as failed.</div>
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="Input.Enabled" class="form-check-input" type="checkbox" />
                    <label asp-for="Input.Enabled" class="form-check-label">
                        Enable Check
                    </label>
                    <div class="form-text">Disabled checks will not run.</div>
                </div>

				<div class="alert alert-info mb-4">
					<i class="icon-info icon-md me-1"></i>
					An alert will be automatically created for this check. You can customize alert settings after the check is created.
				</div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="icon-plus icon-sm"></i>
                        Create Check
                        <span id="create-spinner" class="htmx-indicator spinner-border spinner-border-sm ms-2"></span>
                    </button>
                    <a asp-page="Index" asp-route-workspaceId="@Model.WorkspaceId" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
