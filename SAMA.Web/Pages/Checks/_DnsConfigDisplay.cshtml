@model Dictionary<string, object>
@using SAMA.Shared.Constants

<div class="mt-3 border-top pt-3">
    <h5 class="mb-3">DNS Lookup Configuration</h5>
    
    <dl class="row mb-0">
        <dt class="col-sm-4">Hostname</dt>
        <dd class="col-sm-8">@Model.GetValueOrDefault(ConfigurationKeys.DnsCheck.Hostname)</dd>

        <dt class="col-sm-4">Record Type</dt>
        <dd class="col-sm-8">@Model.GetValueOrDefault(ConfigurationKeys.DnsCheck.RecordType)</dd>

        <dt class="col-sm-4">Expected Values</dt>
        <dd class="col-sm-8 mb-0">
            @if (Model.GetValueOrDefault(ConfigurationKeys.DnsCheck.ExpectedValues) is IEnumerable<object> values && values.Any())
            {
                <code class="text-break">@string.Join(", ", values)</code>
            }
            else
            {
                <span class="text-muted">(Any result accepted)</span>
            }
        </dd>
    </dl>
</div>
