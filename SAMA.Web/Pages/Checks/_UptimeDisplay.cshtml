@model Guid

<div class="card" id="uptimeCard">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Uptime</h5>
        <div class="btn-group btn-group-sm" role="group" id="uptimeTimeRangeButtons">
            <button type="button" class="btn btn-outline-secondary" data-uptime-hours="3" onclick="updateUptimeDisplay('@Model', 3, this)">3h</button>
            <button type="button" class="btn btn-outline-secondary" data-uptime-hours="6" onclick="updateUptimeDisplay('@Model', 6, this)">6h</button>
            <button type="button" class="btn btn-outline-secondary active" data-uptime-hours="24" onclick="updateUptimeDisplay('@Model', 24, this)">24h</button>
            <button type="button" class="btn btn-outline-secondary" data-uptime-hours="168" onclick="updateUptimeDisplay('@Model', 168, this)">7d</button>
        </div>
    </div>
    <div class="card-body">
        <div style="position: relative; min-height: 250px;">
            <div id="uptimeContent">
                <div class="text-center mb-3">
                    <span id="uptimePercentage" class="display-4 fw-bold p-2 rounded uptime-excellent">--%</span>
                </div>
                <div class="progress mb-3" style="height: 25px;">
                    <div id="uptimeBar" class="progress-bar uptime-excellent" role="progressbar" style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">
                    </div>
                </div>
                <div class="row text-center small">
                    <div class="col-4">
                        <div class="text-muted">Available</div>
                        <div id="availableCount" class="fw-semibold">-</div>
                    </div>
                    <div class="col-4">
                        <div class="text-muted">Down</div>
                        <div id="downCount" class="fw-semibold">-</div>
                    </div>
                    <div class="col-4">
                        <div class="text-muted">Total</div>
                        <div id="totalCount" class="fw-semibold">-</div>
                    </div>
                </div>
                <div id="uptimeBreakdown" class="mt-3 text-center small text-muted">
                    <span id="upCountDetail">-</span> Up, <span id="warnCountDetail">-</span> Warn
                </div>
            </div>
            <div id="uptimeLoading" class="text-center py-4 d-none" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
            <div id="uptimeNoData" class="text-center py-4 text-muted d-none" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);">
                No check results available for the selected time period.
            </div>
        </div>
    </div>
</div>

<script>
    (function() {
        function getUptimeClass(percentage) {
            if (percentage >= 99) return 'uptime-excellent';
            if (percentage >= 95) return 'uptime-good';
            return 'uptime-poor';
        }

        window.updateUptimeDisplay = function(checkId, hours, button) {
            const loadingDiv = document.getElementById('uptimeLoading');
            const contentDiv = document.getElementById('uptimeContent');
            const noDataDiv = document.getElementById('uptimeNoData');

            document.querySelectorAll('#uptimeTimeRangeButtons [data-uptime-hours]').forEach(btn => btn.classList.remove('active'));
            button.classList.add('active');

            loadingDiv.classList.remove('d-none');
            noDataDiv.classList.add('d-none');
            contentDiv.style.visibility = 'hidden';

            fetch(`/Checks/Details?handler=Uptime&id=${checkId}&hours=${hours}`)
                .then(response => response.json())
                .then(data => {
                    loadingDiv.classList.add('d-none');

                    if (!data || data.totalChecks === 0) {
                        noDataDiv.classList.remove('d-none');
                        contentDiv.style.visibility = 'hidden';
                        return;
                    }

                    noDataDiv.classList.add('d-none');
                    contentDiv.style.visibility = 'visible';

                    const uptimeClass = getUptimeClass(data.uptimePercentage);
                    const uptimePercentageEl = document.getElementById('uptimePercentage');
                    const uptimeBarEl = document.getElementById('uptimeBar');

                    uptimePercentageEl.textContent = data.uptimePercentage.toFixed(2) + '%';
					uptimePercentageEl.classList.remove('uptime-excellent', 'uptime-good', 'uptime-poor');
					uptimePercentageEl.classList.add(uptimeClass);

                    uptimeBarEl.style.width = data.uptimePercentage + '%';
                    uptimeBarEl.setAttribute('aria-valuenow', data.uptimePercentage);
                    uptimeBarEl.className = 'progress-bar ' + uptimeClass;

                    document.getElementById('availableCount').textContent = data.availableCount;
                    document.getElementById('downCount').textContent = data.downCount;
                    document.getElementById('totalCount').textContent = data.totalChecks;
                    document.getElementById('upCountDetail').textContent = data.upCount;
                    document.getElementById('warnCountDetail').textContent = data.warnCount;
                })
                .catch(error => {
                    console.error('Error loading uptime data:', error);
                    loadingDiv.classList.add('d-none');
                    noDataDiv.classList.remove('d-none');
                    contentDiv.style.visibility = 'hidden';
                });
        };

        document.addEventListener('DOMContentLoaded', function() {
            const defaultButton = document.querySelector('#uptimeTimeRangeButtons [data-uptime-hours="24"]');
            if (defaultButton) {
                window.updateUptimeDisplay('@Model', 24, defaultButton);
            }
        });
    })();
</script>
