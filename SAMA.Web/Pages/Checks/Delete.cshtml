@page
@model SAMA.Web.Pages.Checks.DeleteModel
@{
    ViewData["Title"] = "Delete Check";
    Layout = "_WorkspaceLayout";
}

<h2 class="mb-3 page-header">Delete Check</h2>

<div class="row">
    <div class="col-lg-8">
        <div class="alert alert-danger" role="alert">
            <h5 class="alert-heading">Are you sure you want to delete this check?</h5>
            <p>This action cannot be undone. All historical results and alerts for this check will also be deleted.</p>
        </div>

        <div id="delete-form-container">
            <partial name="_ValidationSummary" model="ViewData.ModelState" />

            <div class="card mb-3">
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Name</dt>
                        <dd class="col-sm-8">@Model.CheckToDelete.Name</dd>

                        <dt class="col-sm-4">Type</dt>
                        <dd class="col-sm-8">
                            <span class="badge bg-info">@Model.CheckToDelete.CheckType</span>
                        </dd>

                        <dt class="col-sm-4">Schedule</dt>
                        <dd class="col-sm-8">
                            <span>@SAMA.Web.Extensions.ScheduleExtensions.ToDisplayString(Model.CheckToDelete.Schedule)</span>
                        </dd>

                        <dt class="col-sm-4">Status</dt>
                        <dd class="col-sm-8">
                            @if (Model.CheckToDelete.Enabled)
                            {
                                <span class="badge bg-success">Enabled</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Disabled</span>
                            }
                        </dd>

                        <dt class="col-sm-4">Created</dt>
                        <dd class="col-sm-8"><time data-timestamp="@Model.CheckToDelete.CreatedAt.ToString("O")" data-format="long">@Model.CheckToDelete.CreatedAt.ToString("MMMM dd, yyyy")</time></dd>

                        <dt class="col-sm-4">Historical Results</dt>
                        <dd class="col-sm-8">
                            <span class="badge bg-info">@Model.CheckToDelete.ResultCount</span>
                        </dd>

                        <dt class="col-sm-4">Configured Alert Rules</dt>
                        <dd class="col-sm-8">
                            <span class="badge bg-info">@Model.CheckToDelete.AlertCount</span>
                        </dd>
                    </dl>
                </div>
            </div>

            @if (Model.CheckToDelete.ResultCount > 0 || Model.CheckToDelete.AlertCount > 0)
            {
                <div class="alert alert-warning">
                    <strong>Warning:</strong> This check has <strong>@Model.CheckToDelete.ResultCount</strong> historical result(s) 
                    and <strong>@Model.CheckToDelete.AlertCount</strong> alert rule(s) that will also be deleted.
                </div>
            }

            <form id="delete-form"
                    method="post"
                    hx-post="/Checks/Delete?id=@Model.CheckToDelete.Id"
                    hx-target="#delete-form-container"
                    hx-swap="outerHTML"
                    hx-select="#delete-form-container"
                    hx-indicator="#delete-spinner">
                
                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-danger">
                        Delete Check
                        <span id="delete-spinner" class="htmx-indicator spinner-border spinner-border-sm ms-2"></span>
                    </button>
                    <a asp-page="Details" asp-route-id="@Model.CheckToDelete.Id" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
