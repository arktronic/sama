@page
@using SAMA.Web.Extensions
@model SAMA.Web.Pages.Alerts.IndexModel
@{
    ViewData["Title"] = $"Alert Rules - {Model.CheckName}";
    Layout = "_WorkspaceLayout";
    var canEdit = await Html.CanEditWorkspaceAsync(Model.WorkspaceId);
}

<div class="d-flex justify-content-between align-items-center mb-3 page-header-row">
    <div>
        <h2 class="mb-1 page-header">Alert Rules</h2>
        <p class="text-muted mb-0">For check: <a asp-page="/Checks/Details" asp-route-id="@Model.CheckId">@Model.CheckName</a></p>
    </div>
    @if (canEdit)
    {
        <a asp-page="Create" asp-route-checkId="@Model.CheckId" class="btn btn-primary">
            <i class="icon-plus icon-sm"></i>
            Create Alert Rule
        </a>
    }
</div>

@if (!Model.Alerts.Any())
{
    <div class="alert alert-info">
        <h5 class="alert-heading">No Alert Rules Configured</h5>
        <p>Create your first alert rule to start receiving notifications when this check fails or enters a degraded state.</p>
        @if (canEdit)
        {
            <a asp-page="Create" asp-route-checkId="@Model.CheckId" class="btn btn-primary">
                <i class="icon-plus icon-sm"></i>
                Create Alert Rule
            </a>
        }
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th class="text-nowrap">Name</th>
                    <th class="text-nowrap">
                        Triggers <i class="icon-circle-question-mark icon-xs text-muted" tabindex="0" data-bs-toggle="popover" data-bs-placement="top" data-bs-trigger="hover focus" data-bs-content="Which check states (Degraded/Down) will trigger this alert rule"></i>
                    </th>
                    <th class="text-nowrap">
                        Threshold <i class="icon-circle-question-mark icon-xs text-muted" tabindex="0" data-bs-toggle="popover" data-bs-placement="top" data-bs-trigger="hover focus" data-bs-content="Number of consecutive failures required before sending a notification"></i>
                    </th>
                    <th class="text-nowrap">
                        Channels <i class="icon-circle-question-mark icon-xs text-muted" tabindex="0" data-bs-toggle="popover" data-bs-placement="top" data-bs-trigger="hover focus" data-bs-content="Notification channels to use. 'All' means all workspace channels will receive the alert rule notification"></i>
                    </th>
                    <th class="text-nowrap">
                        On Recovery <i class="icon-circle-question-mark icon-xs text-muted" tabindex="0" data-bs-toggle="popover" data-bs-placement="top" data-bs-trigger="hover focus" data-bs-content="Whether to send a notification when the check recovers to Up status"></i>
                    </th>
                    <th style="width: 100%;" class="text-nowrap">Status</th>
                    @if (canEdit)
                    {
                        <th class="text-nowrap">Actions</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var alert in Model.Alerts)
                {
                    <tr>
                        <td class="text-nowrap">
                            <a asp-page="Details" asp-route-id="@alert.Id">
                                <strong>@alert.Name</strong>
                            </a>
                        </td>
						<td class="text-nowrap">
                            @if (alert.TriggerOnWarn)
                            {
                                <span class="badge bg-warning text-dark">Degraded</span>
                            }
                            @if (alert.TriggerOnDown)
                            {
                                <span class="badge bg-danger">Down</span>
                            }
                        </td>
						<td class="text-nowrap">
                            @if (alert.FailureThreshold == 1)
                            {
                                <span>Immediate</span>
                            }
                            else
                            {
                                <span>@alert.FailureThreshold consecutive</span>
                            }
                        </td>
                        <td>
                            @if (alert.ChannelCount == 0)
                            {
								<span class="badge bg-info">All</span>
                            }
                            else
                            {
                                <span class="badge bg-info">@alert.ChannelCount</span>
                            }
                        </td>
                        <td class="text-nowrap">
                            @if (alert.SendRecoveryNotification)
                            {
                                <span class="text-success">Send notification</span>
                            }
                            else
                            {
                                <span class="text-muted">Do nothing</span>
                            }
                        </td>
                        <td>
                            @if (alert.Enabled)
                            {
                                <span class="badge bg-success">Enabled</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Disabled</span>
                            }
                        </td>
                        @if (canEdit)
                        {
                            <td>
                                <div class="d-flex gap-3">
                                    <a asp-page="Edit" asp-route-id="@alert.Id" class="btn btn-link table-action-link" title="Edit">
                                        Edit
                                    </a>
                                    <a asp-page="Delete" asp-route-id="@alert.Id" class="btn btn-link table-action-link text-danger" title="Delete">
                                        Delete
                                    </a>
                                </div>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<div class="mt-3">
    <a asp-page="/Checks/Details" asp-route-id="@Model.CheckId" class="btn btn-secondary">
        <i class="icon-arrow-left icon-sm"></i>
        Back to Check
    </a>
</div>
