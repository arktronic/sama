@page
@model SAMA.Web.Pages.Alerts.CreateModel
@{
    ViewData["Title"] = "Create Alert Rule";
    Layout = "_WorkspaceLayout";
}

<div class="mb-3">
    <h2 class="mb-1 page-header">Create Alert Rule</h2>
    <p class="text-muted mb-0">Configure an alert rule and select notification channels for <a asp-page="/Checks/Details" asp-route-id="@Model.CheckId">@Model.CheckName</a></p>
</div>

<div class="row">
    <div class="col-lg-8">
        <div id="create-alert-form-container">
            <form id="create-alert-form"
                  method="post"
                  hx-post="/Alerts/Create?checkId=@Model.CheckId"
                  hx-target="#create-alert-form-container"
                  hx-swap="outerHTML"
                  hx-select="#create-alert-form-container"
                  hx-indicator="#create-spinner">

                <input type="hidden" asp-for="Input.CheckId" />

                <partial name="_ValidationSummary" model="ViewData.ModelState" />

                <div class="mb-3">
                    <label asp-for="Input.Name" class="form-label">Alert Rule Name</label>
                    <input asp-for="Input.Name" class="form-control" required autofocus />
                    <div class="form-text">A descriptive name for this alert rule.</div>
                </div>

                <div class="card mb-3">
                    <div class="card-header">
                        <h5 class="mb-0">Trigger Conditions</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Trigger When Check Status Is:</label>
                            <div class="form-check">
                                <input asp-for="Input.TriggerOnWarn" class="form-check-input" type="checkbox" />
                                <label asp-for="Input.TriggerOnWarn" class="form-check-label">
                                    <span class="badge bg-warning text-dark">Degraded</span> Check degraded but not failed
                                </label>
                            </div>
                            <div class="form-check">
                                <input asp-for="Input.TriggerOnDown" class="form-check-input" type="checkbox" />
                                <label asp-for="Input.TriggerOnDown" class="form-check-label">
                                    <span class="badge bg-danger">Down</span> Down - Check failed
                                </label>
                            </div>
                            <div class="form-text">Select at least one status to trigger the alert rule.</div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.FailureThreshold" class="form-label">Failure Threshold</label>
                            <input asp-for="Input.FailureThreshold" class="form-control" type="number" min="@SAMA.Web.Constants.AlertConstants.MinFailureThreshold" max="@SAMA.Web.Constants.AlertConstants.MaxFailureThreshold" required />
                            <div class="form-text">Number of consecutive failures before triggering the alert rule. Use 1 for immediate notification.</div>
                        </div>

                        <div class="form-check mb-0">
                            <input asp-for="Input.SendRecoveryNotification" class="form-check-input" type="checkbox" />
                            <label asp-for="Input.SendRecoveryNotification" class="form-check-label">
                                Send Recovery Notification
                            </label>
                            <div class="form-text">Send a notification when the check returns to <span class="badge bg-success">Up</span> status.</div>
                        </div>
                    </div>
                </div>

                <div class="card mb-3">
                    <div class="card-header">
                        <h5 class="mb-0">Notification Channels</h5>
                    </div>
                    <div class="card-body">
                        @if (!Model.AvailableChannels.Any())
                        {
                            <div class="alert alert-warning mb-0">
                                <strong>No notification channels available.</strong><br />
                                Please <a asp-page="/NotificationChannels/Create" asp-route-workspaceId="@Model.WorkspaceId">create a notification channel</a> first before configuring alerts.
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info">
                                <strong>Note:</strong> Select specific channels to receive notifications, or leave all unchecked to send to all available channels in this workspace.
                            </div>

                            <div class="mb-0">
                                <label class="form-label">Select Notification Channels (optional)</label>
                                <div class="list-group" style="max-height: 400px; overflow-y: auto;">
                                    @foreach (var channel in Model.AvailableChannels)
                                    {
                                        var isChecked = Model.Input.SelectedChannelIds.Contains(channel.Id);

                                        <label class="list-group-item">
                                            <div class="d-flex align-items-center">
                                                <input type="checkbox" 
                                                       name="Input.SelectedChannelIds" 
                                                       value="@channel.Id" 
                                                       class="form-check-input me-3" 
                                                       checked="@isChecked" />
                                                <div class="flex-grow-1">
                                                    <div class="@(channel.Enabled ? "fw-semibold" : "text-muted")">
                                                        @channel.Name
                                                    </div>
                                                    <small class="text-muted">
                                                        <span class="badge bg-info">@SAMA.Web.Constants.ChannelTypes.GetShortDisplayName(channel.ChannelType)</span>
                                                        @if (!channel.Enabled)
                                                        {
                                                            <span class="badge bg-secondary ms-1">Disabled</span>
                                                        }
                                                    </small>
                                                </div>
                                            </div>
                                        </label>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="mb-4 form-check">
                    <input asp-for="Input.Enabled" class="form-check-input" type="checkbox" />
                    <label asp-for="Input.Enabled" class="form-check-label">
                        Enable Alert Rule
                    </label>
                    <div class="form-text">Disabled alert rules will not send notifications.</div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="icon-plus icon-sm"></i>
                        Create Alert Rule
                        <span id="create-spinner" class="htmx-indicator spinner-border spinner-border-sm ms-2"></span>
                    </button>
                    <a asp-page="Index" asp-route-checkId="@Model.CheckId" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
