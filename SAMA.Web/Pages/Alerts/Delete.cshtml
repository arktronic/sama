@page
@model SAMA.Web.Pages.Alerts.DeleteModel
@{
    ViewData["Title"] = "Delete Alert";
    Layout = "_WorkspaceLayout";
}

<h2 class="mb-3 page-header">Delete Alert</h2>

<div class="row">
    <div class="col-lg-8">
        <div class="alert alert-danger">
            <h5 class="alert-heading">⚠ Warning</h5>
            <p class="mb-0">Are you sure you want to delete this alert? This action cannot be undone.</p>
        </div>

        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">@Model.AlertToDelete.Name</h5>

                <dl class="row mb-0">
                    <dt class="col-sm-4">Check</dt>
                    <dd class="col-sm-8"><a asp-page="/Checks/Details" asp-route-id="@Model.CheckId">@Model.CheckName</a></dd>

                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">
                        @if (Model.AlertToDelete.Enabled)
                        {
                            <span class="badge bg-success">Enabled</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Disabled</span>
                        }
                    </dd>

                    <dt class="col-sm-4">Triggers On</dt>
                    <dd class="col-sm-8">
                        @if (Model.AlertToDelete.TriggerOnWarn)
                        {
                            <span class="badge bg-warning text-dark">Warn</span>
                        }
                        @if (Model.AlertToDelete.TriggerOnDown)
                        {
                            <span class="badge bg-danger">Down</span>
                        }
                    </dd>

                    <dt class="col-sm-4">Failure Threshold</dt>
                    <dd class="col-sm-8">
                        @if (Model.AlertToDelete.FailureThreshold == 1)
                        {
                            <span>Immediate</span>
                        }
                        else
                        {
                            <span>@Model.AlertToDelete.FailureThreshold consecutive</span>
                        }
                    </dd>

                    <dt class="col-sm-4">Channels</dt>
                    <dd class="col-sm-8">@Model.AlertToDelete.Channels.Count channel(s)</dd>

                    <dt class="col-sm-4">Notification History</dt>
                    <dd class="col-sm-8">@Model.AlertToDelete.AlertHistoryCount notification(s) sent</dd>

                    <dt class="col-sm-4">Created</dt>
                    <dd class="col-sm-8 mb-0">@Model.AlertToDelete.CreatedAt.ToString("MMMM dd, yyyy 'at' h:mm tt")</dd>
                </dl>
            </div>
        </div>

        <form method="post">
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">Delete Alert</button>
                <a asp-page="Details" asp-route-id="@Model.AlertToDelete.Id" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
