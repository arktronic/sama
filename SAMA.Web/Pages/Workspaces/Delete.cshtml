@page
@model SAMA.Web.Pages.Workspaces.DeleteModel
@{
    ViewData["Title"] = "Delete Workspace";
}

<h2 class="mb-3 page-header">Delete Workspace</h2>

<div class="row">
    <div class="col-lg-8">
        <div class="alert alert-danger" role="alert">
            <h5 class="alert-heading">Are you sure you want to delete this workspace?</h5>
            <p>This action cannot be undone. All checks, notification channels, and related data will be permanently deleted.</p>
        </div>

        <div id="delete-form-container">
            <partial name="_ValidationSummary" model="ViewData.ModelState" />

            <div class="card mb-3">
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Name</dt>
                        <dd class="col-sm-8">@Model.WorkspaceToDelete.Name</dd>

                        <dt class="col-sm-4">Description</dt>
                        <dd class="col-sm-8">
                            @if (!string.IsNullOrEmpty(Model.WorkspaceToDelete.Description))
                            {
                                @Model.WorkspaceToDelete.Description
                            }
                            else
                            {
                                <span class="text-muted fst-italic">No description</span>
                            }
                        </dd>

                        <dt class="col-sm-4">Visibility</dt>
                        <dd class="col-sm-8">
                            @if (Model.WorkspaceToDelete.IsPublic)
                            {
                                <span class="badge bg-success">Public</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Private</span>
                            }
                        </dd>

                        <dt class="col-sm-4">Created</dt>
                        <dd class="col-sm-8"><time data-timestamp="@Model.WorkspaceToDelete.CreatedAt.ToString("O")" data-format="long">@Model.WorkspaceToDelete.CreatedAt.ToString("MMMM dd, yyyy")</time></dd>

                        <dt class="col-sm-4">Checks</dt>
                        <dd class="col-sm-8">
                            <span class="badge bg-info">@Model.WorkspaceToDelete.CheckCount</span>
                        </dd>

                        <dt class="col-sm-4">Notification Channels</dt>
                        <dd class="col-sm-8">
                            <span class="badge bg-info">@Model.WorkspaceToDelete.NotificationChannelCount</span>
                        </dd>

                        <dt class="col-sm-4">Assigned Users</dt>
                        <dd class="col-sm-8">
                            <span class="badge bg-info">@Model.WorkspaceToDelete.UserCount</span>
                        </dd>
                    </dl>
                </div>
            </div>

            @if (Model.WorkspaceToDelete.CheckCount > 0 || Model.WorkspaceToDelete.NotificationChannelCount > 0)
            {
                <div class="alert alert-warning">
                    <strong>Warning:</strong> This workspace contains <strong>@Model.WorkspaceToDelete.CheckCount</strong> check(s) 
                    and <strong>@Model.WorkspaceToDelete.NotificationChannelCount</strong> notification channel(s) that will also be deleted.
                </div>
            }

            <form id="delete-form"
                  method="post"
                  hx-post="/Workspaces/Delete?id=@Model.WorkspaceToDelete.Id"
                  hx-target="#delete-form-container"
                  hx-swap="outerHTML"
                  hx-select="#delete-form-container"
                  hx-indicator="#delete-spinner">
                
                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-danger">
                        Delete Workspace
                        <span id="delete-spinner" class="htmx-indicator spinner-border spinner-border-sm ms-2"></span>
                    </button>
                    <a asp-page="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
