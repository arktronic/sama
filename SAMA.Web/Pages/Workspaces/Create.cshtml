@page
@model SAMA.Web.Pages.Workspaces.CreateModel
@{
    ViewData["Title"] = "Create Workspace";
}

<h2 class="mb-3 page-header">Create Workspace</h2>

<div class="row">
    <div class="col-lg-8">
        <div id="create-workspace-form-container">
            <form id="create-workspace-form"
                  method="post"
                  hx-post="/Workspaces/Create"
                  hx-target="#create-workspace-form-container"
                  hx-swap="outerHTML"
                  hx-select="#create-workspace-form-container"
                  hx-indicator="#create-spinner">
                
                <partial name="_ValidationSummary" model="ViewData.ModelState" />

                <div class="mb-3">
                    <label asp-for="Input.Name" class="form-label">Workspace Name</label>
                    <input asp-for="Input.Name" class="form-control" required autofocus />
                    <div class="form-text">A descriptive name for this workspace.</div>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Description" class="form-label">Description</label>
                    <textarea asp-for="Input.Description" class="form-control" rows="3"></textarea>
                    <div class="form-text">Optional description of this workspace's purpose.</div>
                </div>

                <div class="mb-4 form-check">
                    <input asp-for="Input.IsPublic" class="form-check-input" type="checkbox" />
                    <label asp-for="Input.IsPublic" class="form-check-label">
                        Public Workspace
                    </label>
                    <div class="form-text">Public workspaces can be viewed by unauthenticated guests.</div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="icon-plus icon-sm"></i>
                        Create Workspace
                        <span id="create-spinner" class="htmx-indicator spinner-border spinner-border-sm ms-2"></span>
                    </button>
                    <a asp-page="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
