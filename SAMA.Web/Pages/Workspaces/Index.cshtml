@page
@using SAMA.Shared.Constants
@model SAMA.Web.Pages.Workspaces.IndexModel
@{
    ViewData["Title"] = "Workspaces";
}

<div class="row mt-4">
    <div class="col">
        <div class="d-flex justify-content-between align-items-center mb-4 page-header-row">
            <h2 class="page-header">@ViewData["Title"]</h2>
            @if (Model.IsAdmin)
            {
                <a asp-page="Create" class="btn btn-primary">
                    <i class="icon-plus icon-sm"></i> Create Workspace
                </a>
            }
        </div>

        @if (!Model.Workspaces.Any())
        {
            @if (Model.IsAdmin)
            {
                <div class="alert alert-info">
                    <h5 class="alert-heading">No Workspaces</h5>
                    <p>Create your first workspace to start organizing checks and alert rules.</p>
                    <a asp-page="Create" class="btn btn-primary">Create Workspace</a>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    <h5 class="alert-heading">No Workspaces Available</h5>
                    <p>There are no public workspaces to view at this time.</p>
                </div>
            }
        }
        else
        {
            @if (Model.IsAuthenticated)
            {
                <p class="text-muted small mb-3">
                    <i class="icon-info icon-xs"></i>
                    Tip: You can set a default workspace in your <a asp-page="/Account/Profile">profile settings</a> to have as your home page.
                </p>
            }
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th class="text-nowrap">
                                Name
                            </th>
                            <th style="width: 100%;" class="text-nowrap">
                                Description
                            </th>
                            <th class="text-nowrap">
                                Visibility <i class="icon-circle-question-mark icon-xs text-muted" tabindex="0" data-bs-toggle="popover" data-bs-placement="top" data-bs-trigger="hover focus" data-bs-html="true" data-bs-content="<strong>Public:</strong> All users can view this workspace<br><strong>Private:</strong> Only users with granted access can view/edit this workspace"></i>
                            </th>
                            <th class="text-nowrap">
                                Health <i class="icon-circle-question-mark icon-xs text-muted" tabindex="0" data-bs-toggle="popover" data-bs-placement="top" data-bs-trigger="hover focus" data-bs-html="true" data-bs-content="Status breakdown of checks in this workspace<br><span class='text-success'>●</span> Up &nbsp;<span class='text-warning'>●</span> Degraded &nbsp;<span class='text-danger'>●</span> Down &nbsp;<span class='text-muted'>●</span> Inactive"></i>
                            </th>
                            <th class="text-nowrap">
                                Channels <i class="icon-circle-question-mark icon-xs text-muted" tabindex="0" data-bs-toggle="popover" data-bs-placement="top" data-bs-trigger="hover focus" data-bs-content="Number of notification channels (email, webhooks, etc.) configured for alerting"></i>
                            </th>
                            <th class="text-nowrap">
                                Users <i class="icon-circle-question-mark icon-xs text-muted" tabindex="0" data-bs-toggle="popover" data-bs-placement="top" data-bs-trigger="hover focus" data-bs-content="Number of users who have been granted access to this workspace"></i>
                            </th>
                            <th class="text-nowrap">
                                Created
                            </th>
                            @if (Model.IsAdmin)
                            {
                                <th>Actions</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var workspace in Model.Workspaces)
                        {
                            <tr>
                                <td>
                                    <a asp-page="/Dashboard/Index" asp-route-workspaceId="@workspace.Id">
                                        <strong>@workspace.Name</strong>
                                    </a>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(workspace.Description))
                                    {
                                        <span class="text-muted">@workspace.Description</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">No description</span>
                                    }
                                </td>
                                <td>
                                    @if (workspace.IsPublic)
                                    {
                                        <span class="badge bg-success">Public</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Private</span>
                                    }
                                </td>
                                <td class="text-nowrap">
                                    @if (workspace.CheckCount == 0)
                                    {
                                        <span class="text-muted">&mdash;</span>
                                    }
                                    else
                                    {
                                        @if (workspace.UpCount > 0)
                                        {
                                            <span class="badge bg-success" title="@workspace.UpCount Up">@workspace.UpCount</span>
                                        }
                                        @if (workspace.WarnCount > 0)
                                        {
                                            <span class="badge bg-warning text-dark" title="@workspace.WarnCount Degraded">@workspace.WarnCount</span>
                                        }
                                        @if (workspace.DownCount > 0)
                                        {
                                            <span class="badge bg-danger" title="@workspace.DownCount Down">@workspace.DownCount</span>
                                        }
                                        var inactiveCount = workspace.CheckCount - workspace.UpCount - workspace.WarnCount - workspace.DownCount;
                                        @if (inactiveCount > 0)
                                        {
                                            <span class="badge bg-secondary" title="@inactiveCount Inactive (disabled or pending)">@inactiveCount</span>
                                        }
                                    }
                                </td>
                                <td>@workspace.NotificationChannelCount</td>
                                <td>@workspace.UserCount</td>
                                <td>
                                    <small class="text-muted text-nowrap">
                                        <time data-timestamp="@workspace.CreatedAt.ToString("O")" data-format="MMM dd, yyyy">
                                            @workspace.CreatedAt.ToString("MMM dd, yyyy")
                                        </time>
                                    </small>
                                </td>
                                @if (Model.IsAdmin)
                                {
                                    <td>
                                        <div class="d-flex gap-3">
                                            <a asp-page="Edit" asp-route-id="@workspace.Id" class="btn btn-link table-action-link" title="Edit">
                                                Edit
                                            </a>
                                            <a asp-page="Delete" asp-route-id="@workspace.Id" class="btn btn-link table-action-link text-danger" title="Delete">
                                                Delete
                                            </a>
                                        </div>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
