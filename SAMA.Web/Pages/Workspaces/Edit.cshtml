@page
@model SAMA.Web.Pages.Workspaces.EditModel
@{
    ViewData["Title"] = "Settings";
    Layout = "_WorkspaceLayout";
}

<h2 class="mb-3 page-header">Settings</h2>

<div class="row">
    <div class="col-lg-8">
        <div id="edit-workspace-form-container">
            <form id="edit-workspace-form"
                  method="post"
                  hx-post="/Workspaces/Edit?id=@Model.Input.Id"
                  hx-target="#edit-workspace-form-container"
                  hx-swap="outerHTML"
                  hx-select="#edit-workspace-form-container"
                  hx-indicator="#edit-spinner">
                
                <input type="hidden" asp-for="Input.Id" />
                
                <partial name="_ValidationSummary" model="ViewData.ModelState" />

                <div class="mb-3">
                    <label asp-for="Input.Name" class="form-label">Workspace Name</label>
                    <input asp-for="Input.Name" class="form-control" required autofocus />
                    <div class="form-text">A descriptive name for this workspace.</div>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Description" class="form-label">Description</label>
                    <textarea asp-for="Input.Description" class="form-control" rows="3"></textarea>
                    <div class="form-text">Optional description of this workspace's purpose.</div>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.DashboardMessage" class="form-label">Dashboard Message</label>
                    <textarea asp-for="Input.DashboardMessage" 
                              class="form-control" 
                              rows="4"
                              hx-post="/Workspaces/Edit?id=@Model.Input.Id&handler=PreviewMarkdown"
                              hx-trigger="keyup changed delay:500ms"
                              hx-target="#dashboard-message-preview"
                              hx-swap="innerHTML"
                              hx-select="unset"
                              name="markdown"></textarea>
                    <div class="form-text">Optional message displayed on the dashboard. Supports Markdown formatting.</div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.Input.DashboardMessage))
                {
                    <div class="mb-3">
                        <label class="form-label text-muted">Preview</label>
                        <div id="dashboard-message-preview" class="card card-body dashboard-message">
                            @Html.Raw(Model.DashboardMessagePreview)
                        </div>
                    </div>
                }
                else
                {
                    <div class="mb-3">
                        <label class="form-label text-muted">Preview</label>
                        <div id="dashboard-message-preview" class="card card-body dashboard-message text-muted">
                            <em>Enter a message above to see a preview...</em>
                        </div>
                    </div>
                }

                <div class="mb-4 form-check">
                    <input asp-for="Input.IsPublic" class="form-check-input" type="checkbox" />
                    <label asp-for="Input.IsPublic" class="form-check-label">
                        Public Workspace
                    </label>
                    <div class="form-text">Public workspaces can be viewed by unauthenticated guests.</div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="icon-save icon-sm"></i>
                        Save Changes
                        <span id="edit-spinner" class="htmx-indicator spinner-border spinner-border-sm ms-2"></span>
                    </button>
                    <a asp-page="/Workspaces/Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
