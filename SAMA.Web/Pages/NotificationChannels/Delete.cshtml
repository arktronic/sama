@page
@model SAMA.Web.Pages.NotificationChannels.DeleteModel
@{
    ViewData["Title"] = "Delete Channel";
    Layout = "_WorkspaceLayout";
}

<h2 class="mb-3 page-header">Delete Channel</h2>

<div class="row">
    <div class="col-lg-8">
        <div class="alert alert-danger" role="alert">
            <h5 class="alert-heading">Are you sure you want to delete this notification channel?</h5>
            <p>This action cannot be undone. This channel will be removed from all alerts that use it.</p>
        </div>

        <div id="delete-form-container">
            <partial name="_ValidationSummary" model="ViewData.ModelState" />

            <div class="card mb-3">
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Name</dt>
                        <dd class="col-sm-8">@Model.ChannelToDelete.Name</dd>

                        <dt class="col-sm-4">Type</dt>
                        <dd class="col-sm-8">
                            <span class="badge bg-info">@SAMA.Web.Constants.ChannelTypes.GetShortDisplayName(Model.ChannelToDelete.ChannelType)</span>
                        </dd>

                        <dt class="col-sm-4">Status</dt>
                        <dd class="col-sm-8">
                            @if (Model.ChannelToDelete.Enabled)
                            {
                                <span class="badge bg-success">Enabled</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Disabled</span>
                            }
                        </dd>

                        <dt class="col-sm-4">Created</dt>
                        <dd class="col-sm-8"><time data-timestamp="@Model.ChannelToDelete.CreatedAt.ToString("O")" data-format="long">@Model.ChannelToDelete.CreatedAt.ToString("MMMM dd, yyyy")</time></dd>

                        <dt class="col-sm-4">Alerts Using Channel</dt>
                        <dd class="col-sm-8">
                            <span class="badge bg-info">@Model.ChannelToDelete.AlertCount</span>
                        </dd>
                    </dl>
                </div>
            </div>

            @if (Model.ChannelToDelete.AlertCount > 0)
            {
                <div class="alert alert-warning">
                    <strong>Warning:</strong> This channel is currently used by <strong>@Model.ChannelToDelete.AlertCount</strong> 
                    @(Model.ChannelToDelete.AlertCount == 1 ? "alert" : "alerts"). 
                    Deleting this channel will remove it from alerts explicitly configured to use it. 
                    Alerts with no remaining channels will send to all workspace channels instead.
                </div>
            }

            <form id="delete-form"
                  method="post"
                  hx-post="/NotificationChannels/Delete?id=@Model.ChannelToDelete.Id"
                  hx-target="#delete-form-container"
                  hx-swap="outerHTML"
                  hx-select="#delete-form-container"
                  hx-indicator="#delete-spinner">
                
                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-danger">
                        Delete Channel
                        <span id="delete-spinner" class="htmx-indicator spinner-border spinner-border-sm ms-2"></span>
                    </button>
                    <a asp-page="Details" asp-route-id="@Model.ChannelToDelete.Id" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
