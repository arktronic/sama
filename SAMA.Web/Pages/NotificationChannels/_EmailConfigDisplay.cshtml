@model Dictionary<string, object>
@using SAMA.Shared.Constants

<div class="mt-3 border-top pt-3">
    <h5 class="mb-3">Email Configuration</h5>
    
    <dl class="row mb-0">
        <dt class="col-sm-4">SMTP Host</dt>
        <dd class="col-sm-8">@Model.GetValueOrDefault(ConfigurationKeys.Email.SmtpHost)</dd>

        <dt class="col-sm-4">SMTP Port</dt>
        <dd class="col-sm-8">@Model.GetValueOrDefault(ConfigurationKeys.Email.SmtpPort)</dd>

        <dt class="col-sm-4">Use Implicit SSL/TLS</dt>
        <dd class="col-sm-8">
            @(Model.GetValueOrDefault(ConfigurationKeys.Email.UseSsl) as bool? == true ? "Yes" : "No")
        </dd>

        <dt class="col-sm-4">Username</dt>
        <dd class="col-sm-8">
            <span class="d-inline-block">@Model.GetValueOrDefault(ConfigurationKeys.Email.Username)</span>
        </dd>

        <dt class="col-sm-4">Password</dt>
        <dd class="col-sm-8">
            <span class="text-muted font-monospace d-inline-block">@Model.GetValueOrDefault(ConfigurationKeys.Email.Password)</span>
        </dd>

        <dt class="col-sm-4">From Address</dt>
        <dd class="col-sm-8">@Model.GetValueOrDefault(ConfigurationKeys.Email.FromAddress)</dd>

        <dt class="col-sm-4">Recipients</dt>
        <dd class="col-sm-8 mb-0">
            @if (Model.GetValueOrDefault(ConfigurationKeys.Email.Recipients) is IEnumerable<object> recipients && recipients.Count() > 0)
            {
                <div>
                    @foreach (var recipient in recipients)
                    {
                        <span class="badge bg-secondary me-1">@recipient.ToString()</span>
                    }
                </div>
            }
            else
            {
                <span class="text-muted">(None configured)</span>
            }
        </dd>
    </dl>
</div>
