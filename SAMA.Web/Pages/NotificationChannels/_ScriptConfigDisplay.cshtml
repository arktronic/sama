@model Dictionary<string, object>
@using SAMA.Shared.Constants

<div class="mt-3 border-top pt-3">
    <h5 class="mb-3">Script Configuration</h5>
    
    <dl class="row mb-0">
        <dt class="col-sm-4">Script Path / Interpreter</dt>
        <dd class="col-sm-8">
            <code>@Model.GetValueOrDefault(ConfigurationKeys.Script.Path)</code>
        </dd>

        <dt class="col-sm-4">Arguments</dt>
        <dd class="col-sm-8">
            @{
                var arguments = Model.GetValueOrDefault(ConfigurationKeys.Script.Arguments)?.ToString();
            }
            @if (!string.IsNullOrWhiteSpace(arguments))
            {
                <code>@arguments</code>
            }
            else
            {
                <span class="text-muted">(None)</span>
            }
        </dd>

        @{
            var scriptContent = Model.GetValueOrDefault(ConfigurationKeys.Script.Content)?.ToString();
        }
        @if (!string.IsNullOrWhiteSpace(scriptContent))
        {
            <dt class="col-sm-4">Inline Script</dt>
            <dd class="col-sm-8 mb-0">
                <pre class="bg-light p-2 rounded small mb-0" style="max-height: 200px; overflow-y: auto;"><code>@scriptContent</code></pre>
            </dd>
        }
    </dl>
</div>
