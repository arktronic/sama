@page
@using SAMA.Web.Extensions
@model SAMA.Web.Pages.NotificationChannels.IndexModel
@{
    ViewData["Title"] = "Notification Channels";
    Layout = "_WorkspaceLayout";
    var canEdit = await Html.CanEditWorkspaceAsync(Model.WorkspaceId);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0 page-header">Notification Channels</h2>
    @if (canEdit)
    {
        <a asp-page="Create" asp-route-workspaceId="@Model.WorkspaceId" class="btn btn-primary">
            <i class="icon-plus icon-sm"></i>
            Create Channel
        </a>
    }
</div>

@if (!Model.NotificationChannels.Any())
{
    <div class="alert alert-info">
        <h5 class="alert-heading">No Notification Channels</h5>
        <p>Create your first notification channel to start sending notifications when checks fail.</p>
        @if (canEdit)
        {
            <a asp-page="Create" asp-route-workspaceId="@Model.WorkspaceId" class="btn btn-primary">
                <i class="icon-plus icon-sm"></i>
                Create Notification Channel
            </a>
        }
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th style="width: 100%;">Name</th>
                    <th>Type</th>
                    <th>Status</th>
                    <th>Created</th>
                    @if (canEdit)
                    {
                        <th>Actions</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var channel in Model.NotificationChannels)
                {
                    <tr>
                        <td>
                            <a asp-page="Details" asp-route-id="@channel.Id">
                                <strong>@channel.Name</strong>
                            </a>
                        </td>
                        <td>
                            <span class="badge bg-info">@SAMA.Web.Constants.ChannelTypes.GetShortDisplayName(channel.ChannelType)</span>
                        </td>
                        <td>
                            @if (channel.Enabled)
                            {
                                <span class="badge bg-success">Enabled</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Disabled</span>
                            }
                        </td>
                        <td class="text-nowrap">
                            <small class="text-muted">
                                <time data-timestamp="@channel.CreatedAt.ToString("O")" data-format="MMM dd, yyyy">
                                    @channel.CreatedAt.ToString("MMM dd, yyyy")
                                </time>
                            </small>
                        </td>
                        @if (canEdit)
                        {
                            <td>
                                <div class="d-flex gap-3">
                                    <a asp-page="Edit" asp-route-id="@channel.Id" class="text-decoration-none fw-semibold" title="Edit">
                                        Edit
                                    </a>
                                    <a asp-page="Delete" asp-route-id="@channel.Id" class="text-decoration-none text-danger fw-semibold" title="Delete">
                                        Delete
                                    </a>
                                </div>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
