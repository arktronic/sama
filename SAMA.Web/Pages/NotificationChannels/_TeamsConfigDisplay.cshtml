@model Dictionary<string, object>
@using SAMA.Shared.Constants

<div class="mt-3 border-top pt-3">
    <h5 class="mb-3">Microsoft Teams Configuration</h5>
    
    <dl class="row mb-0">
        <dt class="col-sm-4">Webhook URL</dt>
        <dd class="col-sm-8 mb-0">
            <code class="text-bg-secondary">@Model.GetValueOrDefault(ConfigurationKeys.Webhook.WebhookUrl)</code>
            <div class="form-text mt-1">
                <small>Full webhook URL is hidden for security. The token portion is masked.</small>
            </div>
        </dd>
    </dl>
</div>
