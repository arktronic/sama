@model SAMA.Web.Models.NotificationChannelInputBase
@using SAMA.Web.Constants

<div class="mt-3 border-top pt-3">
    <h5 class="mb-3">Script Configuration</h5>
    
    <div class="mb-3">
        <label for="Input_ScriptPath" class="form-label">Script Path / Interpreter</label>
        <input asp-for="ScriptPath" id="Input_ScriptPath" name="Input.ScriptPath" class="form-control font-monospace" placeholder="/path/to/script.sh" />
        <span asp-validation-for="ScriptPath" class="text-danger"></span>
        <div class="form-text">
            Full path to the script or command to execute.
            <br>If using inline script content below, specify the interpreter (e.g., <code>bash</code>, <code>python3</code>, <code>powershell</code>).
        </div>
    </div>

    <div class="mb-3">
        <label for="Input_ScriptArguments" class="form-label">Arguments <small class="text-muted">(optional, required for inline scripts)</small></label>
        <input asp-for="ScriptArguments" id="Input_ScriptArguments" name="Input.ScriptArguments" class="form-control font-monospace" placeholder="--flag value" />
        <span asp-validation-for="ScriptArguments" class="text-danger"></span>
        <div class="form-text">
            Command-line arguments to pass to the script.
            <br>For inline scripts, include <code class="text-bg-secondary">@ChannelDefaults.ScriptFilePlaceholder</code> where the temp script file path should be inserted.
            <br><strong>Examples:</strong> <code class="text-bg-secondary">@ChannelDefaults.ScriptFilePlaceholder</code> | <code class="text-bg-secondary">-u @ChannelDefaults.ScriptFilePlaceholder</code> | <code class="text-bg-secondary">-File @ChannelDefaults.ScriptFilePlaceholder</code>
        </div>
    </div>

    <div class="mb-3">
        <label for="Input_ScriptContent" class="form-label">Inline Script Content <small class="text-muted">(optional)</small></label>
        <textarea asp-for="ScriptContent" id="Input_ScriptContent" name="Input.ScriptContent" class="form-control font-monospace" rows="8" placeholder="#!/bin/bash&#10;# Your script here...&#10;echo &quot;Notification received&quot;"></textarea>
        <span asp-validation-for="ScriptContent" class="text-danger"></span>
        <div class="form-text">
            Enter script content directly instead of referencing an external file.
            <br>When using inline content, set <strong>Script Path</strong> to the interpreter and include <code class="text-bg-secondary">@ChannelDefaults.ScriptFilePlaceholder</code> in arguments.
        </div>
    </div>

    <div class="alert alert-info">
        <strong>Environment Variables:</strong> SAMA will pass notification data as environment variables. Note that some variables may not always be set.
        
        <p class="mt-2 mb-1"><strong>Status Alert Notifications:</strong></p>
        <ul class="mb-2">
            <li><code class="text-bg-secondary">SAMA_CHECK_NAME</code> - Name of the check</li>
            <li><code class="text-bg-secondary">SAMA_CHECK_ID</code> - Check GUID</li>
            <li><code class="text-bg-secondary">SAMA_STATUS</code> - Current status (Up, Warn, Down)</li>
            <li><code class="text-bg-secondary">SAMA_IS_RECOVERY</code> - Whether this is a recovery notification (True/False)</li>
            <li><code class="text-bg-secondary">SAMA_CONSECUTIVE_FAILURES</code> - Number of consecutive failures</li>
            <li><code class="text-bg-secondary">SAMA_ERROR_MESSAGE</code> - Error message</li>
            <li><code class="text-bg-secondary">SAMA_RESPONSE_TIME_MS</code> - Response time in milliseconds</li>
            <li><code class="text-bg-secondary">SAMA_TIMESTAMP</code> - ISO 8601 timestamp</li>
            <li><code class="text-bg-secondary">SAMA_WORKSPACE</code> - Workspace name</li>
        </ul>
        
        <p class="mb-1"><strong>Status Change Event Notifications:</strong></p>
        <ul class="mb-2">
            <li><code class="text-bg-secondary">SAMA_CHECK_NAME</code> - Name of the check</li>
            <li><code class="text-bg-secondary">SAMA_CHECK_ID</code> - Check GUID</li>
            <li><code class="text-bg-secondary">SAMA_PREVIOUS_STATUS</code> - Status before the change (Up, Warn, Down)</li>
            <li><code class="text-bg-secondary">SAMA_NEW_STATUS</code> - Status after the change (Up, Warn, Down)</li>
            <li><code class="text-bg-secondary">SAMA_ERROR_MESSAGE</code> - Error message</li>
            <li><code class="text-bg-secondary">SAMA_RESPONSE_TIME_MS</code> - Response time in milliseconds</li>
            <li><code class="text-bg-secondary">SAMA_TIMESTAMP</code> - ISO 8601 timestamp</li>
            <li><code class="text-bg-secondary">SAMA_WORKSPACE</code> - Workspace name</li>
        </ul>
        
        <p class="mb-1"><strong>Lifecycle Event Notifications:</strong></p>
        <ul class="mb-0">
            <li><code class="text-bg-secondary">SAMA_EVENT_TYPE</code> - Event type (CheckCreated, CheckUpdated, CheckDeleted)</li>
            <li><code class="text-bg-secondary">SAMA_CHECK_NAME</code> - Name of the check</li>
            <li><code class="text-bg-secondary">SAMA_CHECK_ID</code> - Check GUID</li>
            <li><code class="text-bg-secondary">SAMA_CHECK_TYPE</code> - Type of check (Http, Tcp, Ping, etc.)</li>
            <li><code class="text-bg-secondary">SAMA_WORKSPACE</code> - Workspace name</li>
            <li><code class="text-bg-secondary">SAMA_PERFORMED_BY</code> - Email of the user who performed the action</li>
            <li><code class="text-bg-secondary">SAMA_CHANGED_FIELDS</code> - Comma-separated list of changed field names</li>
            <li><code class="text-bg-secondary">SAMA_TIMESTAMP</code> - ISO 8601 timestamp</li>
        </ul>
    </div>

    <div class="alert alert-warning">
        <strong>Security Note:</strong> The script will be executed with the same permissions as the SAMA application. 
        Ensure the script path is secure and trusted.
    </div>
</div>
