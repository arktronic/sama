@page
@using SAMA.Shared.Constants
@using SAMA.Web.Extensions
@model SAMA.Web.Pages.Dashboard.IndexModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_WorkspaceLayout";
    var canEdit = await Html.CanEditWorkspaceAsync(Model.WorkspaceId);
}

<div class="d-flex justify-content-between align-items-center mb-4 page-header-row">
    <h2 class="mb-0 page-header">
        Dashboard
        @if (Model.Checks.Any())
        {
            <span class="live-indicator" id="live-indicator" title="Live — content refreshes automatically" hx-swap-oob="true"></span>
        }
    </h2>
    @if (canEdit)
    {
        <div class="d-flex gap-2">
            <a asp-page="/Checks/Create" asp-route-workspaceId="@Model.WorkspaceId" class="btn btn-primary">
                <i class="icon-plus icon-sm"></i>
                Create Check
            </a>
        </div>
    }
</div>

<div class="d-none" id="htmx-refresh-placeholder"
     hx-get="/Dashboard/Index?workspaceId=@Model.WorkspaceId&timelineHours=@Model.TimelineHours&trendsHours=@Model.TrendsHours"
     hx-trigger="every @(Model.RefreshIntervalSeconds)s"
     hx-swap="none"></div>

@if (!string.IsNullOrEmpty(Model.DashboardMessageHtml))
{
    <div class="mb-4" id="dashboard-message-container" hx-swap-oob="true">
        <div class="card">
            <div class="card-body dashboard-message">
                @Html.Raw(Model.DashboardMessageHtml)
            </div>
        </div>
    </div>
}

@if (!Model.Checks.Any())
{
    <div class="alert alert-info">
        <i class="icon-info icon-md me-2"></i>
        <strong>No checks configured yet.</strong>
        <p class="mb-0 mt-2">Get started by creating your first monitoring check.</p>
    </div>
}
else
{
    <div id="dashboard-content">
        @{
            var downChecks = Model.Checks.Where(c => c.Enabled && c.LastStatus == CheckStatuses.Down).ToList();
            var warnChecks = Model.Checks.Where(c => c.Enabled && c.LastStatus == CheckStatuses.Warn).ToList();
            var upCount = Model.Checks.Count(c => c.Enabled && c.LastStatus == CheckStatuses.Up);
            var warnCount = Model.Checks.Count(c => c.Enabled && c.LastStatus == CheckStatuses.Warn);
            var downCount = Model.Checks.Count(c => c.Enabled && c.LastStatus == CheckStatuses.Down);
            var pendingCount = Model.Checks.Count(c => c.LastStatus == null && c.Enabled);
            var disabledCount = Model.Checks.Count(c => !c.Enabled);
            var allPending = upCount == 0 && !downChecks.Any() && !warnChecks.Any() && pendingCount > 0;
            var statusClass = downChecks.Any() ? "status-danger" : warnChecks.Any() ? "status-warning" : allPending ? "status-pending" : "";
        }
        <div class="card status-overview mb-4 @statusClass" id="status-overview-card" hx-swap-oob="true">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div class="status-overview-left">
                        @if (downChecks.Any())
                        {
                            <div class="d-flex align-items-center mb-1">
                                <i class="icon-circle-x text-danger icon-lg me-2 flex-shrink-0 fw-black"></i>
                                <span class="fs-5 fw-semibold">@downChecks.Count @(downChecks.Count == 1 ? "check" : "checks") down@(warnChecks.Any() ? $" · {warnChecks.Count} warning" : "")</span>
                            </div>
                            <div class="status-overview-details">
                                <span class="text-muted me-1">Down:</span>
                                @for (var i = 0; i < downChecks.Count; i++)
                                {
                                    <a asp-page="/Checks/Details" asp-route-id="@downChecks[i].Id" class="status-overview-link">@downChecks[i].Name</a>@(i < downChecks.Count - 1 ? ", " : "")
                                }
                            </div>
                            @if (warnChecks.Any())
                            {
                                <div class="status-overview-details">
                                    <span class="text-muted me-1">Warn:</span>
                                    @for (var i = 0; i < warnChecks.Count; i++)
                                    {
                                        <a asp-page="/Checks/Details" asp-route-id="@warnChecks[i].Id" class="status-overview-link">@warnChecks[i].Name</a>@(i < warnChecks.Count - 1 ? ", " : "")
                                    }
                                </div>
                            }
                        }
                        else if (warnChecks.Any())
                        {
                            <div class="d-flex align-items-center mb-1">
                                <i class="icon-triangle-alert text-warning icon-lg me-2 flex-shrink-0 fw-black"></i>
                                <span class="fs-5 fw-semibold">@warnChecks.Count @(warnChecks.Count == 1 ? "check" : "checks") warning</span>
                            </div>
                            <div class="status-overview-details">
                                <span class="text-muted me-1">Warn:</span>
                                @for (var i = 0; i < warnChecks.Count; i++)
                                {
                                    <a asp-page="/Checks/Details" asp-route-id="@warnChecks[i].Id" class="status-overview-link">@warnChecks[i].Name</a>@(i < warnChecks.Count - 1 ? ", " : "")
                                }
                            </div>
                        }
                        else if (upCount == 0 && pendingCount > 0)
                        {
                            <div class="d-flex align-items-center">
                                <i class="icon-clock text-secondary icon-lg me-2 flex-shrink-0 fw-black"></i>
                                <span class="fs-5 fw-semibold">Waiting for checks to run...</span>
                            </div>
                        }
                        else
                        {
                            <div class="d-flex align-items-center">
                                <i class="icon-circle-check text-success icon-lg me-2 flex-shrink-0 fw-black"></i>
                                <span class="fs-5 fw-semibold">All systems operational</span>
                            </div>
                        }
                    </div>
                    <div class="status-overview-counts text-end">
                        <span class="status-count-success fw-semibold">@upCount</span> <span class="text-muted">Up</span>
                        <span class="text-muted mx-1">·</span>
                        <span class="status-count-warning fw-semibold">@warnCount</span> <span class="text-muted">Warn</span>
                        <span class="text-muted mx-1">·</span>
                        <span class="status-count-danger fw-semibold">@downCount</span> <span class="text-muted">Down</span>
                        @if (pendingCount > 0 || disabledCount > 0)
                        {
                            <br />
                            @if (pendingCount > 0)
                            {
                                <span class="fw-semibold">@pendingCount</span> <span class="text-muted">Pending</span>
                                @if (disabledCount > 0)
                                {
                                    <span class="text-muted mx-1">·</span>
                                }
                            }
                            @if (disabledCount > 0)
                            {
                                <span class="fw-semibold">@disabledCount</span> <span class="text-muted">Disabled</span>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="mb-4">
            <partial name="_IncidentTimelineChart" model="Model.IncidentTimeline" />
        </div>

        <div class="mb-4">
            <partial name="_ResponseTimeTrendsChart" model="Model.ResponseTimeTrends" />
        </div>

        <div class="row">
            <div class="col-lg-8">
                <div class="card" id="check-status-card">
                    <div class="card-header">
                        <h5 class="mb-0">Check Status</h5>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th style="width: 50px;"></th>
                                        <th class="text-nowrap">Name</th>
                                        <th class="text-nowrap">Type</th>
                                        <th style="width: 100%;" class="text-nowrap">Status</th>
                                        <th class="text-nowrap">Response Time</th>
                                        <th class="text-nowrap">Last Checked</th>
                                    </tr>
                                </thead>
                                <tbody id="check-status-tbody" hx-swap-oob="true">
                                    @foreach (var check in Model.Checks)
                                    {
                                        <tr>
                                            <td class="text-center">
                                                @if (!check.Enabled)
                                                {
                                                    <i class="icon-pause text-muted icon-md fw-black" title="Disabled"></i>
                                                }
                                                else if (check.LastStatus == CheckStatuses.Up)
                                                {
                                                    <i class="icon-circle-check text-success icon-md fw-black" title="Up"></i>
                                                }
                                                else if (check.LastStatus == CheckStatuses.Warn)
                                                {
                                                    <i class="icon-triangle-alert text-warning icon-md fw-black" title="Warning"></i>
                                                }
                                                else if (check.LastStatus == CheckStatuses.Down)
                                                {
                                                    <i class="icon-circle-x text-danger icon-md fw-black" title="Down"></i>
                                                }
                                                else
                                                {
                                                    <i class="icon-clock text-secondary icon-md fw-black" title="Pending"></i>
                                                }
                                            </td>
                                            <td>
                                                <a asp-page="/Checks/Details" asp-route-id="@check.Id" class="text-decoration-none fw-semibold">
                                                    @check.Name
                                                </a>
                                            </td>
                                            <td>
                                                <span class="badge bg-info">
                                                    @SAMA.Shared.Constants.CheckTypes.GetShortDisplayName(check.CheckType)
                                                </span>
                                            </td>
                                            <td>
                                                @if (!check.Enabled)
                                                {
                                                    <span class="badge bg-secondary">Disabled</span>
                                                }
                                                else if (check.LastStatus == CheckStatuses.Up)
                                                {
                                                    <span class="badge bg-success">Up</span>
                                                }
                                                else if (check.LastStatus == CheckStatuses.Warn)
                                                {
                                                    <span class="badge bg-warning text-dark">Warning</span>
                                                    @if (!string.IsNullOrEmpty(check.LastErrorMessage))
                                                    {
                                                        <br />
                                                        <small class="text-muted" title="@check.LastErrorMessage">
                                                            @(check.LastErrorMessage.Length > 50 ? check.LastErrorMessage.Substring(0, 50) + "..." : check.LastErrorMessage)
                                                        </small>
                                                    }
                                                }
                                                else if (check.LastStatus == CheckStatuses.Down)
                                                {
                                                    <span class="badge bg-danger">Down</span>
                                                    @if (!string.IsNullOrEmpty(check.LastErrorMessage))
                                                    {
                                                        <br />
                                                        <small class="text-muted" title="@check.LastErrorMessage">
                                                            @(check.LastErrorMessage.Length > 50 ? check.LastErrorMessage.Substring(0, 50) + "..." : check.LastErrorMessage)
                                                        </small>
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">Pending</span>
                                                }
                                            </td>
                                            <td>
                                                @if (check.LastResponseTimeMs.HasValue)
                                                {
                                                    <span>@check.LastResponseTimeMs ms</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">—</span>
                                                }
                                            </td>
                                            <td>
                                                @if (check.LastCheckedAt.HasValue)
                                                {
                                                    var timeSince = DateTimeOffset.UtcNow - check.LastCheckedAt.Value;
                                                    if (timeSince.TotalMinutes < 1)
                                                    {
                                                        <span>Just now</span>
                                                    }
                                                    else if (timeSince.TotalMinutes < 60)
                                                    {
                                                        <span>@((int)timeSince.TotalMinutes)m ago</span>
                                                    }
                                                    else if (timeSince.TotalHours < 24)
                                                    {
                                                        <span>@((int)timeSince.TotalHours)h ago</span>
                                                    }
                                                    else
                                                    {
                                                        <span>@((int)timeSince.TotalDays)d ago</span>
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="text-muted">Never</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card sticky-lg-top" id="recent-alerts-card" hx-swap-oob="true">
                    <div class="card-header">
                        <h5 class="mb-0">Recent Alerts</h5>
                    </div>
                    <div class="card-body p-0">
                        @if (!Model.RecentAlerts.Any())
                        {
                            <div class="p-4 text-center text-muted">
                                <i class="icon-bell icon-2xl mb-2"></i>
                                <p class="mb-0">No alerts sent yet</p>
                            </div>
                        }
                        else
                        {
                            <div class="list-group list-group-flush">
                                @foreach (var alert in Model.RecentAlerts)
                                {
                                    <a asp-page="/Checks/Details" asp-route-id="@alert.CheckId" class="list-group-item list-group-item-action text-decoration-none">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            @if (alert.Status == CheckStatuses.Up)
                                            {
                                                <span class="badge bg-success">
                                                    <i class="icon-circle-check icon-xs"></i>
                                                    Recovery
                                                </span>
                                            }
                                            else if (alert.Status == CheckStatuses.Warn)
                                            {
                                                <span class="badge bg-warning text-dark">
                                                    <i class="icon-triangle-alert icon-xs"></i>
                                                    Warning
                                                </span>
                                            }
                                            else if (alert.Status == CheckStatuses.Down)
                                            {
                                                <span class="badge bg-danger">
                                                    <i class="icon-circle-x icon-xs"></i>
                                                    Down
                                                </span>
                                            }
                                            <small class="text-muted">
                                                @{
                                                    var timeSince = DateTimeOffset.UtcNow - alert.SentAt;
                                                    if (timeSince.TotalMinutes < 1)
                                                    {
                                                        <span>Just now</span>
                                                    }
                                                    else if (timeSince.TotalMinutes < 60)
                                                    {
                                                        <span>@((int)timeSince.TotalMinutes)m ago</span>
                                                    }
                                                    else if (timeSince.TotalHours < 24)
                                                    {
                                                        <span>@((int)timeSince.TotalHours)h ago</span>
                                                    }
                                                    else
                                                    {
                                                        <span>@((int)timeSince.TotalDays)d ago</span>
                                                    }
                                                }
                                            </small>
                                        </div>
                                        <div>
                                            <span class="fw-semibold d-block text-body">
                                                @alert.CheckName
                                            </span>
                                            <small class="text-muted">@alert.AlertName</small>
                                        </div>
                                    </a>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}
