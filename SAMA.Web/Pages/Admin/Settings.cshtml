@page
@model SAMA.Web.Pages.Admin.SettingsModel
@{
    ViewData["Title"] = "System Settings";
}

<h2 class="mb-3 page-header">System Settings</h2>

<div class="row">
    <div class="col-xl-8">
        <div id="settings-form-container">
            <form id="settings-form"
                  method="post"
                  hx-post="/Admin/Settings"
                  hx-target="#settings-form-container"
                  hx-swap="outerHTML"
                  hx-select="#settings-form-container"
                  hx-indicator="#save-spinner">

                <partial name="_ValidationSummary" model="ViewData.ModelState" />

                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title mb-3">
                            <i class="icon-database icon-lg me-2"></i>
                            Data Retention
                        </h5>
                        <p class="text-muted mb-4">
                            Configure how long historical data is kept before automatic cleanup. Lower values save storage space but reduce available history. Minimum 30 days.
                        </p>

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label asp-for="Input.CheckResultsRetentionDays" class="form-label"></label>
                                <input asp-for="Input.CheckResultsRetentionDays" class="form-control" type="number" min="30" max="3650" required />
                                <span asp-validation-for="Input.CheckResultsRetentionDays" class="text-danger"></span>
                                <div class="form-text">Default: 365 days</div>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="Input.AlertHistoryRetentionDays" class="form-label"></label>
                                <input asp-for="Input.AlertHistoryRetentionDays" class="form-control" type="number" min="30" max="3650" required />
                                <span asp-validation-for="Input.AlertHistoryRetentionDays" class="text-danger"></span>
                                <div class="form-text">Default: 365 days</div>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="Input.AuditLogRetentionDays" class="form-label"></label>
                                <input asp-for="Input.AuditLogRetentionDays" class="form-control" type="number" min="30" max="3650" required />
                                <span asp-validation-for="Input.AuditLogRetentionDays" class="text-danger"></span>
                                <div class="form-text">Default: 365 days</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title mb-3">
                            <i class="icon-gauge icon-lg me-2"></i>
                            Dashboard
                        </h5>
                        <p class="text-muted mb-4">
                            Control dashboard behavior and display limits.
                        </p>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Input.DashboardRefreshIntervalSeconds" class="form-label"></label>
                                <input asp-for="Input.DashboardRefreshIntervalSeconds" class="form-control" type="number" min="1" max="300" required />
                                <span asp-validation-for="Input.DashboardRefreshIntervalSeconds" class="text-danger"></span>
                                <div class="form-text">How often the dashboard auto-refreshes (default: 5 seconds)</div>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Input.MaxRecentAlerts" class="form-label"></label>
                                <input asp-for="Input.MaxRecentAlerts" class="form-control" type="number" min="10" max="500" required />
                                <span asp-validation-for="Input.MaxRecentAlerts" class="text-danger"></span>
                                <div class="form-text">Maximum alerts shown in dashboard sidebar (default: 20)</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title mb-3">
                            <i class="icon-circle-check icon-lg me-2"></i>
                            Check Execution
                        </h5>
                        <p class="text-muted mb-4">
                            Configure default timeout for new checks.
                        </p>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Input.DefaultCheckTimeoutSeconds" class="form-label"></label>
                                <input asp-for="Input.DefaultCheckTimeoutSeconds" class="form-control" type="number" min="5" max="300" required />
                                <span asp-validation-for="Input.DefaultCheckTimeoutSeconds" class="text-danger"></span>
                                <div class="form-text">Default timeout for new checks (default: 30 seconds)</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title mb-3">
                            <i class="icon-bell icon-lg me-2"></i>
                            Notifications
                        </h5>
                        <p class="text-muted mb-4">
                            Configure notification delivery settings.
                        </p>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Input.NotificationTimeoutSeconds" class="form-label"></label>
                                <input asp-for="Input.NotificationTimeoutSeconds" class="form-control" type="number" min="5" max="300" required />
                                <span asp-validation-for="Input.NotificationTimeoutSeconds" class="text-danger"></span>
                                <div class="form-text">Timeout for notification delivery attempts (default: 30 seconds)</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title mb-3">
                            <i class="icon-users icon-lg me-2"></i>
                            Anonymous Users
                        </h5>
                        <p class="text-muted mb-4">
                            Configure the default experience for anonymous (unauthenticated) visitors.
                        </p>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Input.AnonymousDefaultWorkspaceId" class="form-label">Default Workspace</label>
                                <select asp-for="Input.AnonymousDefaultWorkspaceId" asp-items="Model.AvailableWorkspaces" class="form-select"></select>
                                <span asp-validation-for="Input.AnonymousDefaultWorkspaceId" class="text-danger"></span>
                                <div class="form-text">When anonymous users visit the home page, they'll be redirected to this workspace's dashboard. Only public workspaces are available.</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="icon-save icon-sm"></i>
                        Save Settings
                        <span id="save-spinner" class="htmx-indicator spinner-border spinner-border-sm ms-2"></span>
                    </button>
                </div>
            </form>
        </div>

        <div class="alert alert-info mt-4">
            <h6 class="alert-heading">
                <i class="icon-info me-2"></i>
                Important Notes
            </h6>
            <ul class="mb-0">
                <li>Data cleanup runs nightly based on retention settings.</li>
                <li>Dashboard refresh changes require users to reload their browsers.</li>
                <li>Reducing retention periods does not immediately delete existing data - wait for the next cleanup cycle.</li>
            </ul>
        </div>
    </div>

    <div class="col-xl-4">
        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title mb-3">
                    <i class="icon-download icon-lg me-2"></i>
                    Export Configuration
                </h5>
                <p class="text-muted mb-3">
                    Export all workspaces, checks, alerts, and notification channels to an encrypted file.
                </p>

                @if (TempData["ExportError"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <div class="me-3">
                            <i class="icon-circle-alert icon-sm me-2"></i>
                            @TempData["ExportError"]
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form method="post" asp-page-handler="Export" novalidate>
                    <div class="mb-3">
                        <label asp-for="ExportInput.Password" class="form-label"></label>
                        <input asp-for="ExportInput.Password" class="form-control" type="password" placeholder="Enter encryption password" />
                        <div class="form-text">Minimum 14 characters. You'll need this password to import.</div>
                    </div>
                    <button type="submit" class="btn btn-primary">
                        <i class="icon-download icon-sm me-1"></i>
                        Download Export
                    </button>
                </form>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title mb-3">
                    <i class="icon-upload icon-lg me-2"></i>
                    Import Configuration
                </h5>
                <p class="text-muted mb-3">
                    Import workspaces, checks, alerts, and notification channels from an export file.
                </p>

                @if (TempData["ImportError"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <div class="me-3">
                            <i class="icon-circle-alert icon-sm me-2"></i>
                            @TempData["ImportError"]
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @if (TempData["ImportSuccess"] != null)
                {
                    var importWarnings = TempData["ImportWarnings"] as List<string>;
                    var hasWarnings = importWarnings?.Count > 0;
                    <div class="alert @(hasWarnings ? "alert-warning" : "alert-success") alert-dismissible fade show" role="alert">
                        <div class="me-3">
                            <i class="@(hasWarnings ? "icon-triangle-alert" : "icon-circle-check") icon-sm me-2"></i>
                            @TempData["ImportSuccess"]
                            @if (hasWarnings)
                            {
                                <ul class="mb-0 mt-2">
                                    @foreach (var warning in importWarnings!)
                                    {
                                        <li>@warning</li>
                                    }
                                </ul>
                            }
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form method="post" asp-page-handler="Import" enctype="multipart/form-data" novalidate>
                    <div class="mb-3">
                        <label asp-for="ImportInput.File" class="form-label"></label>
                        <input asp-for="ImportInput.File" class="form-control" type="file" accept=".json" />
                        <div class="form-text">Select a SAMA export file (.json)</div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ImportInput.Password" class="form-label"></label>
                        <input asp-for="ImportInput.Password" class="form-control" type="password" placeholder="Enter decryption password" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="ImportInput.ImportStrategy" class="form-label"></label>
                        <select asp-for="ImportInput.ImportStrategy" asp-items="Model.ImportStrategyOptions" class="form-select"></select>
                        <div class="form-text">
                            Choose how to handle workspaces that already exist.<br />
                            <span class="fw-bold">Note:</span> Importing with "Merge" will not overwrite existing checks or notification channels.
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary">
                        <i class="icon-upload icon-sm me-1"></i>
                        Import
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
