@page
@model SAMA.Web.Pages.Admin.LogsModel
@{
    ViewData["Title"] = "Application Logs";
}

<h2 class="mb-3 page-header">Application Logs</h2>

<div class="row">
    <div class="col-12">
        <div class="alert alert-info mb-4">
            <h6 class="alert-heading">
                <i class="icon-info me-2 mb-1"></i>
                About Application Logs
            </h6>
            <p class="mb-2">
                This page shows the most recent log entries from the application. For complete logs, use your container runtime or process manager.
            </p>
        </div>

        <div class="card">
            <div class="card-body">
                <h5 class="card-title mb-3">
                    <i class="icon-list me-2 mb-1"></i>
                    Recent Log Entries
                </h5>

                @if (!Model.LogEntries.Any())
                {
                    <div class="alert alert-info">
                        <i class="icon-info me-2"></i>
                        No log entries found.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-hover">
                            <thead>
                                <tr>
                                    <th style="width: 140px;" class="text-nowrap">Timestamp</th>
                                    <th style="width: 100px;" class="text-nowrap">Level</th>
                                    <th class="text-nowrap">Source</th>
                                    <th style="width: 100%;" class="text-nowrap">Message</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in Model.LogEntries)
                                {
                                    var rowClass = log.Level switch
                                    {
                                        "Error" or "Fatal" => "table-danger",
                                        "Warning" => "table-warning",
                                        _ => ""
                                    };

                                    <tr class="@rowClass">
                                        <td class="text-nowrap small">
                                            <time data-timestamp="@log.Timestamp.ToString("o")" data-format="MMM dd, HH:mm:ss.SSS">
                                                @log.Timestamp.ToString("HH:mm:ss.fff")
                                            </time>
                                        </td>
                                        <td>
                                            @if (log.Level == "Error" || log.Level == "Fatal")
                                            {
                                                <span class="badge bg-danger">@log.Level</span>
                                            }
                                            else if (log.Level == "Warning")
                                            {
                                                <span class="badge bg-warning text-dark">@log.Level</span>
                                            }
                                            else if (log.Level == "Information")
                                            {
                                                <span class="badge bg-info text-dark">Info</span>
                                            }
                                            else if (log.Level == "Debug")
                                            {
                                                <span class="badge bg-secondary">@log.Level</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-light text-dark">@log.Level</span>
                                            }
                                        </td>
                                        <td class="small text-muted">
                                            @if (!string.IsNullOrEmpty(log.SourceContext))
                                            {
                                                var shortContext = log.SourceContext.Split('.').LastOrDefault() ?? log.SourceContext;
                                                <span title="@log.SourceContext">@shortContext</span>
                                            }
                                        </td>
                                        <td class="small" style="max-width: 0;">
                                            <div>@log.Message</div>
                                            @if (!string.IsNullOrEmpty(log.Exception))
                                            {
                                                <details class="mt-1">
                                                    <summary class="text-danger" style="cursor: pointer;">Exception details</summary>
                                                    <div style="overflow-x: auto;">
                                                        <pre class="mt-2 mb-0 p-2 bg-light border rounded small text-danger"><code>@log.Exception</code></pre>
                                                    </div>
                                                </details>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
