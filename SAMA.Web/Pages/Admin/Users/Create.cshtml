@page
@model SAMA.Web.Pages.Admin.Users.CreateModel
@{
    ViewData["Title"] = "Create User";
}

<h2 class="mb-3 page-header">Create User</h2>

<div class="row">
    <div class="col-lg-8">
        <div id="create-user-form-container">
            <form id="create-user-form"
                  method="post"
                  hx-post="/Admin/Users/Create"
                  hx-target="#create-user-form-container"
                  hx-swap="outerHTML"
                  hx-select="#create-user-form-container"
                  hx-indicator="#create-spinner">
                
                <partial name="_ValidationSummary" model="ViewData.ModelState" />

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label">Email</label>
                    <input asp-for="Input.Email" class="form-control" type="email" required autofocus />
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label">Password</label>
                    <input asp-for="Input.Password" class="form-control" type="password" required />
                    <div class="form-text">
                        Must be at least 14 characters.
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.ConfirmPassword" class="form-label">Confirm Password</label>
                    <input asp-for="Input.ConfirmPassword" class="form-control" type="password" required />
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="Input.IsAdmin" class="form-check-input" type="checkbox" />
                    <label asp-for="Input.IsAdmin" class="form-check-label">
                        Administrator (full system access)
                    </label>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="icon-plus icon-sm"></i>
                        Create User
                        <span id="create-spinner" class="htmx-indicator spinner-border spinner-border-sm ms-2"></span>
                    </button>
                    <a asp-page="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
