@page
@using Microsoft.AspNetCore.Identity
@using SAMA.Data.Entities
@model SAMA.Web.Pages.Admin.Users.ResetPasswordModel
@inject UserManager<ApplicationUser> UserManager
@{
    ViewData["Title"] = "Reset Password";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8 col-lg-6">
        <h2 class="page-header">@ViewData["Title"]</h2>
        <hr />

        <div class="alert alert-warning">
            <i class="icon-triangle-alert me-1"></i>
            You are about to reset the password for <strong>@Model.UserEmail</strong>. The user will need to use the new password to log in.
        </div>

        <div id="reset-password-form-container">
            <form id="reset-password-form"
                  method="post"
                  hx-post="/Admin/Users/ResetPassword?id=@Model.Input.UserId"
                  hx-target="#reset-password-form-container"
                  hx-swap="outerHTML"
                  hx-select="#reset-password-form-container"
                  hx-indicator="#reset-spinner">
                
                <input type="hidden" asp-for="Input.UserId" />
                
                <partial name="_ValidationSummary" model="ViewData.ModelState" />

                <div class="mb-3">
                    <label asp-for="Input.NewPassword" class="form-label">New Password</label>
                    @if (ViewData.ModelState.IsValid)
                    {
                        <input asp-for="Input.NewPassword" class="form-control" type="password" required autofocus />
                    }
                    else
                    {
                        <input asp-for="Input.NewPassword" class="form-control" type="password" required />
                    }
                    <div class="form-text">
                        Must be at least @UserManager.Options.Password.RequiredLength characters. Consider a passphrase for better security and memorability.
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Input.ConfirmPassword" class="form-label">Confirm New Password</label>
                    <input asp-for="Input.ConfirmPassword" class="form-control" type="password" required />
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-warning">
                        Reset Password
                        <span id="reset-spinner" class="htmx-indicator spinner-border spinner-border-sm ms-2"></span>
                    </button>
                    <a asp-page="Details" asp-route-id="@Model.Input.UserId" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
