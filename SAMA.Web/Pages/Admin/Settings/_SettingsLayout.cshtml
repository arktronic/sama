@{
    Layout = "_Layout";
    var activeTab = ViewData["ActiveSettingsTab"]?.ToString();
}

<h2 class="mb-3 page-header">System Options</h2>

<ul class="nav nav-tabs mb-0" id="settings-tabs">
    <li class="nav-item">
        <a class="nav-link @(activeTab == "General" ? "active" : "")"
           asp-page="/Admin/Settings/Index">
            <i class="icon-settings icon-sm"></i>
            General
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(activeTab == "ImportExport" ? "active" : "")"
           asp-page="/Admin/Settings/ImportExport">
            <i class="icon-arrow-up-down icon-sm"></i>
            Import / Export
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(activeTab == "Ldap" ? "active" : "")"
           asp-page="/Admin/Settings/Ldap">
            <i class="icon-folder-tree icon-sm"></i>
            LDAP
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(activeTab == "GroupMappings" ? "active" : "")"
           asp-page="/Admin/Settings/GroupMappings">
            <i class="icon-users icon-sm"></i>
            Group Mappings
        </a>
    </li>
</ul>
<hr class="mt-0" />

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var tabs = document.getElementById('settings-tabs');
        var active = tabs && tabs.querySelector('.nav-link.active');
        if (tabs && active) {
            var offset = active.offsetLeft - (tabs.clientWidth / 2) + (active.offsetWidth / 2);
            tabs.scrollLeft = Math.max(0, offset);
        }
    });
</script>

@RenderBody()
