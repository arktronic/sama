@page
@model SAMA.Web.Pages.Admin.Settings.IndexModel
@{
    Layout = "_SettingsLayout";
    ViewData["Title"] = "System Options";
    ViewData["ActiveSettingsTab"] = "General";
}

<div class="row">
    <div class="col-xl-8">
        <div id="settings-form-container">
            <form id="settings-form"
                  method="post"
                  hx-post="/Admin/Settings"
                  hx-target="#settings-form-container"
                  hx-swap="outerHTML"
                  hx-select="#settings-form-container"
                  hx-indicator="#save-spinner">

                <partial name="_ValidationSummary" model="ViewData.ModelState" />

                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title mb-3">
                            <i class="icon-database icon-lg me-2"></i>
                            Data Retention
                        </h5>
                        <p class="text-muted mb-4">
                            Configure how long historical data is kept before automatic cleanup. Lower values save storage space but reduce available history. Minimum 30 days.
                        </p>

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label asp-for="Input.CheckResultsRetentionDays" class="form-label"></label>
                                <input asp-for="Input.CheckResultsRetentionDays" class="form-control" type="number" min="30" max="3650" required />
                                <span asp-validation-for="Input.CheckResultsRetentionDays" class="text-danger"></span>
                                <div class="form-text">Default: 365 days</div>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="Input.AlertHistoryRetentionDays" class="form-label"></label>
                                <input asp-for="Input.AlertHistoryRetentionDays" class="form-control" type="number" min="30" max="3650" required />
                                <span asp-validation-for="Input.AlertHistoryRetentionDays" class="text-danger"></span>
                                <div class="form-text">Default: 365 days</div>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="Input.AuditLogRetentionDays" class="form-label"></label>
                                <input asp-for="Input.AuditLogRetentionDays" class="form-control" type="number" min="30" max="3650" required />
                                <span asp-validation-for="Input.AuditLogRetentionDays" class="text-danger"></span>
                                <div class="form-text">Default: 365 days</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title mb-3">
                            <i class="icon-monitor icon-lg me-2"></i>
                            Display
                        </h5>
                        <p class="text-muted mb-4">
                            Control auto-refresh behavior and display limits.
                        </p>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Input.DashboardRefreshIntervalSeconds" class="form-label"></label>
                                <input asp-for="Input.DashboardRefreshIntervalSeconds" class="form-control" type="number" min="1" max="300" required />
                                <span asp-validation-for="Input.DashboardRefreshIntervalSeconds" class="text-danger"></span>
                                <div class="form-text">How often pages with status info auto-refresh (default: 5 seconds)</div>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Input.MaxRecentAlerts" class="form-label"></label>
                                <input asp-for="Input.MaxRecentAlerts" class="form-control" type="number" min="10" max="500" required />
                                <span asp-validation-for="Input.MaxRecentAlerts" class="text-danger"></span>
                                <div class="form-text">Maximum alerts shown in dashboard sidebar (default: 20)</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title mb-3">
                            <i class="icon-circle-check icon-lg me-2"></i>
                            Check Execution
                        </h5>
                        <p class="text-muted mb-4">
                            Configure default timeout and scheduling time zone for checks. The time zone applies to cron schedule expressions only; simple interval schedules are unaffected.
                        </p>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Input.DefaultCheckTimeoutSeconds" class="form-label"></label>
                                <input asp-for="Input.DefaultCheckTimeoutSeconds" class="form-control" type="number" min="5" max="3600" required />
                                <span asp-validation-for="Input.DefaultCheckTimeoutSeconds" class="text-danger"></span>
                                <div class="form-text">Default timeout for new checks (default: 30 seconds)</div>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Input.TimeZone" class="form-label"></label>
                                <select asp-for="Input.TimeZone" asp-items="Model.AvailableTimeZones" class="form-select"></select>
                                <span asp-validation-for="Input.TimeZone" class="text-danger"></span>
                                <div class="form-text">Time zone for cron expressions (default: UTC)</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title mb-3">
                            <i class="icon-bell icon-lg me-2"></i>
                            Notifications
                        </h5>
                        <p class="text-muted mb-4">
                            Configure notification delivery settings.
                        </p>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Input.NotificationTimeoutSeconds" class="form-label"></label>
                                <input asp-for="Input.NotificationTimeoutSeconds" class="form-control" type="number" min="5" max="300" required />
                                <span asp-validation-for="Input.NotificationTimeoutSeconds" class="text-danger"></span>
                                <div class="form-text">Timeout for notification delivery attempts (default: 30 seconds)</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title mb-3">
                            <i class="icon-users icon-lg me-2"></i>
                            Anonymous Users
                        </h5>
                        <p class="text-muted mb-4">
                            Configure the default experience for anonymous (unauthenticated) visitors.
                        </p>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Input.AnonymousDefaultWorkspaceId" class="form-label">Default Workspace</label>
                                <select asp-for="Input.AnonymousDefaultWorkspaceId" asp-items="Model.AvailableWorkspaces" class="form-select"></select>
                                <span asp-validation-for="Input.AnonymousDefaultWorkspaceId" class="text-danger"></span>
                                <div class="form-text">When anonymous users visit the home page, they'll be redirected to this workspace's dashboard. Only public workspaces are available.</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="icon-save icon-sm"></i>
                        Save Settings
                        <span id="save-spinner" class="htmx-indicator spinner-border spinner-border-sm ms-2"></span>
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="col-xl-4">
        <div class="alert alert-info">
            <h6 class="alert-heading">
                <i class="icon-info me-2"></i>
                Important Notes
            </h6>
            <ul class="mb-0">
                <li>Data cleanup runs nightly based on retention settings.</li>
                <li>Dashboard refresh changes require users to reload their browsers.</li>
                <li>Reducing retention periods does not immediately delete existing data - wait for the next cleanup cycle.</li>
            </ul>
        </div>
    </div>
</div>
