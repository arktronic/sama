@page
@using Microsoft.AspNetCore.Identity
@using SAMA.Data.Entities
@model SAMA.Web.Pages.Account.ProfileModel
@inject UserManager<ApplicationUser> UserManager
@{
    ViewData["Title"] = "Profile";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8 col-lg-6">
        <h2 class="page-header">@ViewData["Title"]</h2>
        <hr />

        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title">Account Information</h5>
                <p class="mb-1"><strong>Email:</strong> @User.Identity?.Name</p>
                <p class="text-muted small">Account created: @((await UserManager.GetUserAsync(User))?.CreatedAt.ToString("MMMM dd, yyyy"))</p>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title mb-3">Preferences</h5>

                <div id="preferences-form-container">
                    <form id="preferences-form"
                          method="post"
                          asp-page-handler="Preferences"
                          hx-post="/Account/Profile?handler=Preferences"
                          hx-target="#preferences-form-container"
                          hx-swap="outerHTML"
                          hx-select="#preferences-form-container"
                          hx-indicator="#preferences-spinner">
                        
                        <partial name="_ValidationSummary" model="ViewData.ModelState" />

                        <div class="mb-3">
                            <label asp-for="PreferencesInput.DefaultWorkspaceId" class="form-label">Default Workspace</label>
                            <select asp-for="PreferencesInput.DefaultWorkspaceId" asp-items="Model.AvailableWorkspaces" class="form-select"></select>
                            <div class="form-text">
                                When you visit the home page, you'll be redirected to this workspace's dashboard.
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary">
                            Save Preferences
                            <span id="preferences-spinner" class="htmx-indicator spinner-border spinner-border-sm ms-2"></span>
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <h5 class="card-title mb-3">Change Password</h5>

                <div id="password-form-container">
                    <form id="password-form"
                          method="post"
                          hx-post="/Account/Profile"
                          hx-target="#password-form-container"
                          hx-swap="outerHTML"
                          hx-select="#password-form-container"
                          hx-indicator="#password-spinner">
                        
                        <partial name="_ValidationSummary" model="ViewData.ModelState" />

                        <div class="mb-3">
                            <label asp-for="Input.CurrentPassword" class="form-label">Current Password</label>
                            <input asp-for="Input.CurrentPassword" class="form-control" type="password" required />
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.NewPassword" class="form-label">New Password</label>
                            <input asp-for="Input.NewPassword" class="form-control" type="password" required />
                            <div class="form-text">
                                Must be at least 14 characters.
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.ConfirmPassword" class="form-label">Confirm New Password</label>
                            <input asp-for="Input.ConfirmPassword" class="form-control" type="password" required />
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                Change Password
                                <span id="password-spinner" class="htmx-indicator spinner-border spinner-border-sm ms-2"></span>
                            </button>
                            <a asp-page="/Index" class="btn btn-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
