@using SAMA.Web.Services
@inject ApplicationStateService AppState

@functions {
    bool IsActiveNav(string section)
    {
        var path = ViewContext.HttpContext.Request.Path.Value ?? "";
        return section switch
        {
            "Workspaces" => path.StartsWith("/Workspaces", StringComparison.OrdinalIgnoreCase)
                         || path.StartsWith("/Dashboard", StringComparison.OrdinalIgnoreCase)
                         || path.StartsWith("/Checks", StringComparison.OrdinalIgnoreCase)
                         || path.StartsWith("/Alerts", StringComparison.OrdinalIgnoreCase)
                         || path.StartsWith("/NotificationChannels", StringComparison.OrdinalIgnoreCase)
                         || path.StartsWith("/EventSubscriptions", StringComparison.OrdinalIgnoreCase),
            "Users" => path.StartsWith("/Admin/Users", StringComparison.OrdinalIgnoreCase),
            "Settings" => path.StartsWith("/Admin/Settings", StringComparison.OrdinalIgnoreCase),
            "About" => path.StartsWith("/About", StringComparison.OrdinalIgnoreCase),
            _ => false
        };
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SAMA</title>
    <link rel="icon" type="image/png" href="~/favicon.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
	<link rel="stylesheet" href="~/lib/lucide-static/font/lucide.css" />
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SAMA.Web.styles.css" asp-append-version="true" />
    <script src="~/lib/luxon/build/global/luxon.min.js"></script>
    <script src="~/js/theme.js" asp-append-version="true"></script>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light border-bottom mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index"><img src="~/sama-logo.svg" alt="SAMA" style="height: 45px;" /></a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <i class="icon-menu icon-lg"></i>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link @(IsActiveNav("Workspaces") ? "active" : "")" asp-page="/Workspaces/Index">Workspaces</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(IsActiveNav("Users") ? "active" : "")" asp-page="/Admin/Users/Index">Users</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(IsActiveNav("Settings") ? "active" : "")" asp-page="/Admin/Settings/Index">System Options</a>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link @(IsActiveNav("About") ? "active" : "")" asp-page="/About">About</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <button type="button" class="theme-toggle" data-theme-toggle aria-label="Toggle theme">
                                <i data-theme-icon="light" class="icon-sun icon-md" style="display: none;"></i>
                                <i data-theme-icon="dark" class="icon-moon icon-md"></i>
                            </button>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    @User.Identity.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                    <li><a class="dropdown-item" asp-page="/Account/Profile">Profile</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form method="post" asp-page="/Account/Logout" class="d-inline">
                                            <button type="button" class="dropdown-item" onclick="this.closest('form').submit()">Logout</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Account/Login">Login</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            SAMA v@(AppState.Version)
        </div>
    </footer>

    <partial name="_ServiceUnavailableModal" />
    <partial name="_RequestErrorModal" />

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/htmx/dist/htmx.min.js"></script>
    <script src="~/lib/chart.js/dist/chart.umd.min.js"></script>
    <script src="~/lib/chartjs-adapter-luxon/dist/chartjs-adapter-luxon.umd.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
