@* Modal dialog that displays when htmx encounters errors on non-periodic requests *@
<div class="modal fade" id="htmxErrorModal" tabindex="-1" aria-labelledby="htmxErrorModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h5 class="modal-title" id="htmxErrorModalLabel">
                    <i class="icon-circle-alert me-2 mb-1"></i>
                    Error
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p id="htmx-error-message" class="mb-0"></p>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal">OK</button>
            </div>
        </div>
    </div>
</div>
