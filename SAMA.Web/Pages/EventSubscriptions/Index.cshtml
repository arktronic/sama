@page
@using SAMA.Web.Extensions
@model SAMA.Web.Pages.EventSubscriptions.IndexModel
@{
    ViewData["Title"] = "Event Subscriptions";
    Layout = "_WorkspaceLayout";
    var canEdit = await Html.CanEditWorkspaceAsync(Model.WorkspaceId);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0 page-header">Event Subscriptions</h2>
</div>

<div class="alert alert-info">
    <h5 class="alert-heading">About Event Subscriptions</h5>
    <p class="mb-0">
        Event subscriptions allow notification channels to receive workspace-level events immediately when they occur.
        These are <strong>raw, unfiltered</strong> notifications sent on every event, unlike alerts, which have thresholds and conditions.
    </p>
</div>

@if (Model.EventSubscriptionGroups.All(g => g.SubscribedChannelCount == 0))
{
    <div class="alert alert-info">
        <h5 class="alert-heading">No Event Subscriptions</h5>
        <p>No channels are currently subscribed to workspace events.</p>
        @if (canEdit)
        {
            <p class="mb-0">Click <strong>Manage Subscriptions</strong> on any event type below to get started.</p>
        }
    </div>
}

<div class="table-responsive">
    <table class="table table-hover">
        <thead>
            <tr>
                <th style="width: 100%;" class="text-nowrap">Event Type</th>
                <th class="text-nowrap">
                    Subscribed Channels <i class="icon-circle-question-mark icon-xs text-muted" tabindex="0" data-bs-toggle="popover" data-bs-placement="top" data-bs-trigger="hover focus" data-bs-content="Notification channels receiving this event type when it occurs"></i>
                </th>
                @if (canEdit)
                {
                    <th class="text-nowrap">Action</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var group in Model.EventSubscriptionGroups)
            {
                <tr>
                    <td>
                        <div>
                            <strong>@SAMA.Web.Constants.EventTypes.GetDisplayName(group.EventType)</strong>
                        </div>
                        <small class="text-muted">
                            @switch (group.EventType)
                            {
                                case SAMA.Web.Constants.EventTypes.CheckCreated:
                                    <text>Fired when a new check is created</text>
                                    break;
                                case SAMA.Web.Constants.EventTypes.CheckUpdated:
                                    <text>Fired when check configuration is modified</text>
                                    break;
                                case SAMA.Web.Constants.EventTypes.CheckDeleted:
                                    <text>Fired when a check is deleted</text>
                                    break;
                                case SAMA.Web.Constants.EventTypes.CheckStatusChanged:
                                    <text>Fired on every status transition (Up↔Warn↔Down)</text>
                                    break;
                            }
                        </small>
                    </td>
                    <td class="text-nowrap">
                        @if (group.SubscribedChannelCount > 0)
                        {
                            <span class="badge bg-success">@group.SubscribedChannelCount / @group.TotalChannelCount</span>
                            <div class="mt-1">
                                <small class="text-muted">@string.Join(", ", group.SubscribedChannelNames)</small>
                            </div>
                        }
                        else
                        {
                            <span class="badge bg-secondary">None</span>
                        }
                    </td>
                    @if (canEdit)
                    {
                        <td>
                            <a asp-page="Manage" 
                               asp-route-workspaceId="@Model.WorkspaceId" 
                               asp-route-eventType="@group.EventType"
                               class="btn btn-sm btn-primary">
                                Manage Subscriptions
                            </a>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="card mt-4">
    <div class="card-body">
        <h5 class="card-title">Event Subscriptions vs. Alerts</h5>
        <div class="row">
            <div class="col-md-6">
                <h6>Event Subscriptions</h6>
                <ul class="mb-0">
                    <li>Workspace-level (all checks)</li>
                    <li>Immediate, unfiltered notifications</li>
                    <li>No thresholds or conditions</li>
                    <li>For audit, integration, streaming</li>
                </ul>
            </div>
            <div class="col-md-6">
                <h6>Alerts</h6>
                <ul class="mb-0">
                    <li>Per-check configuration</li>
                    <li>Filtered by threshold (e.g., 3 failures)</li>
                    <li>Conditional triggers (warn/down)</li>
                    <li>For actionable notifications</li>
                </ul>
            </div>
        </div>
    </div>
</div>
